<!-- Usage: <%- include('../partials/genreCard', { genre }) %> -->
<a href="/genre/<%= genre.slug %>" class="genre-card block" style="height: 200px;">

  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="<%= genre.bgImage %>"
      alt="<%= genre.name %>"
      class="w-full h-full object-cover transition-transform duration-500 hover:scale-110"
      onerror="this.style.display='none'"
    />
  </div>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

  <!-- Content -->
  <div class="absolute bottom-0 left-0 right-0 p-4 text-white">
    <div class="flex items-center gap-2 mb-1">
      <span class="text-xl"><%= genre.emoji %></span>
      <h3 class="font-serif text-xl font-bold"><%= genre.name %></h3>
    </div>
    <p class="text-white/75 text-xs leading-relaxed line-clamp-2">
      <%= genre.description %>
    </p>
  </div>

  <!-- Hover glow border -->
  <div class="absolute inset-0 rounded-2xl ring-2 ring-transparent
              hover:ring-amber-400 transition-all duration-300"></div>
</a>