<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
  <style>
    /* ── Community card cover: tighter height ── */
    .comm-cover { height: 160px; }

    /* ── Chat panel ── */
    #chat-panel {
      position: fixed; inset: 0; z-index: 60;
      display: none; align-items: center; justify-content: center;
      background: rgba(30,15,5,0.72);
      backdrop-filter: blur(6px);
    }
    #chat-panel.open { display: flex; }

    .chat-box {
      width: min(820px, 96vw);
      height: min(88vh, 680px);
      background: #fffdf8;
      border-radius: 20px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: 0 32px 80px rgba(60,30,10,0.35);
    }

    /* header */
    .chat-header {
      background: linear-gradient(135deg, #7a3a0a 0%, #b8641a 100%);
      color: #fff;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }
    .chat-header-img {
      width: 44px; height: 44px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid rgba(255,255,255,0.4);
      flex-shrink: 0;
    }
    .chat-header-info { flex: 1; min-width: 0; }
    .chat-header-info h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1rem; font-weight: 700;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .chat-header-info p { font-size: 11px; opacity: 0.8; margin-top: 1px; }

    /* body: messages + sidebar */
    .chat-body {
      flex: 1; display: flex; min-height: 0;
    }

    /* message area */
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      background: #faf5ee;
    }
    .chat-messages::-webkit-scrollbar { width: 4px; }
    .chat-messages::-webkit-scrollbar-thumb { background: #c9a96e55; border-radius: 4px; }

    .msg-row {
      display: flex;
      gap: 8px;
      max-width: 72%;
    }
    .msg-row.mine { align-self: flex-end; flex-direction: row-reverse; }
    .msg-row.other { align-self: flex-start; }

    .msg-avatar {
      width: 30px; height: 30px;
      border-radius: 50%;
      background: linear-gradient(135deg, #c9a96e, #8b6914);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 11px; font-weight: 700;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .msg-bubble {
      padding: 8px 12px;
      border-radius: 16px;
      font-size: 13px;
      line-height: 1.5;
      word-break: break-word;
    }
    .msg-row.mine  .msg-bubble {
      background: linear-gradient(135deg, #8b4a14, #b8641a);
      color: #fff;
      border-bottom-right-radius: 4px;
    }
    .msg-row.other .msg-bubble {
      background: #fff;
      color: #3d1f08;
      border-bottom-left-radius: 4px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }

    .msg-meta {
      font-size: 10px;
      margin-top: 3px;
      opacity: 0.55;
      text-align: right;
    }
    .msg-row.other .msg-meta { text-align: left; }
    .msg-author {
      font-size: 10px;
      font-weight: 700;
      color: #b8641a;
      margin-bottom: 2px;
    }

    /* input bar */
    .chat-input-bar {
      padding: 12px 14px;
      background: #fff;
      border-top: 1px solid #e8d5b7;
      display: flex;
      gap: 10px;
      align-items: flex-end;
      flex-shrink: 0;
    }
    .chat-input-bar textarea {
      flex: 1;
      border: 1.5px solid #e8d5b7;
      border-radius: 20px;
      padding: 9px 14px;
      font-size: 13px;
      font-family: 'Lato', sans-serif;
      color: #3d1f08;
      background: #faf7f2;
      resize: none;
      outline: none;
      max-height: 80px;
      line-height: 1.5;
    }
    .chat-input-bar textarea:focus { border-color: #b8641a; }
    .chat-send-btn {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #8b4a14, #b8641a);
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      transition: transform 0.2s, opacity 0.2s;
    }
    .chat-send-btn:hover { transform: scale(1.08); opacity: 0.9; }
    .chat-send-btn svg { width: 16px; height: 16px; fill: #fff; }

    /* members sidebar */
    .chat-sidebar {
      width: 200px;
      border-left: 1px solid #f0e4d0;
      background: #fff;
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      overflow: hidden;
    }
    .sidebar-title {
      padding: 12px 14px 8px;
      font-size: 11px;
      font-weight: 700;
      color: #7a4a28;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-bottom: 1px solid #f0e4d0;
      flex-shrink: 0;
    }
    .sidebar-members {
      flex: 1;
      overflow-y: auto;
      padding: 6px 0;
    }
    .sidebar-members::-webkit-scrollbar { width: 3px; }
    .sidebar-members::-webkit-scrollbar-thumb { background: #c9a96e44; }

    .member-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 14px;
      font-size: 12px;
      color: #4a2810;
    }
    .member-avatar {
      width: 26px; height: 26px;
      border-radius: 50%;
      background: linear-gradient(135deg, #c9a96e, #8b6914);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 10px; font-weight: 700;
      flex-shrink: 0;
    }
    .member-name { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .admin-badge {
      font-size: 9px; background: #fef3c7; color: #92400e;
      padding: 1px 5px; border-radius: 999px; font-weight: 700;
      flex-shrink: 0;
    }
    .remove-btn {
      font-size: 10px; color: #ef4444;
      background: none; border: none; cursor: pointer;
      opacity: 0; transition: opacity 0.2s;
      padding: 2px 4px;
    }
    .member-row:hover .remove-btn { opacity: 1; }

    /* sidebar admin actions */
    .sidebar-actions {
      border-top: 1px solid #f0e4d0;
      padding: 10px 14px;
      flex-shrink: 0;
    }
    .delete-btn {
      width: 100%;
      padding: 7px 0;
      background: #fff0f0;
      color: #ef4444;
      border: 1.5px solid #fca5a5;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s;
    }
    .delete-btn:hover { background: #fee2e2; }

    /* Empty state */
    .chat-empty {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 8px; color: #b8a090; font-size: 13px; text-align: center;
      padding: 20px;
    }

    /* Create modal */
    #create-modal {
      position: fixed; inset: 0; z-index: 70;
      display: none; align-items: center; justify-content: center;
      background: rgba(44,24,16,0.72);
      backdrop-filter: blur(4px);
    }
    #create-modal.open { display: flex; }

    /* Image preview */
    #cover-preview-wrap {
      display: none;
      margin-top: 8px;
      position: relative;
      width: 100%; height: 120px;
      border-radius: 12px;
      overflow: hidden;
      border: 1.5px solid #e8d5b7;
    }
    #cover-preview-img { width: 100%; height: 100%; object-fit: cover; }
    #cover-preview-wrap button {
      position: absolute; top: 6px; right: 6px;
      background: rgba(0,0,0,0.55); color: #fff;
      border: none; border-radius: 50%; width: 22px; height: 22px;
      font-size: 12px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }

    /* Search input */
    .search-bar-wrap {
      position: relative;
    }
    .search-bar-wrap svg {
      position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
      width: 16px; height: 16px; color: #c9a96e;
    }
    .search-input {
      width: 100%;
      padding: 10px 14px 10px 40px;
      border: 1.5px solid #e8d5b7;
      border-radius: 999px;
      font-size: 13px;
      color: #3d1f08;
      background: #fff;
      outline: none;
      font-family: 'Lato', sans-serif;
      transition: border-color 0.2s;
    }
    .search-input:focus { border-color: #b8641a; }
  </style>
</head>
<body class="bg-cream min-h-screen">

<%- include('../partials/navbar') %>

<!-- Header -->
<div class="pt-28 pb-8 px-4 text-center"
     style="background: linear-gradient(180deg, #faf0dc 0%, #faf7f2 100%);">
  <h1 class="font-serif text-5xl font-bold text-amber-900 mb-3">Reading Communities</h1>
  <p class="text-amber-600 max-w-xl mx-auto text-sm">
    Join groups of readers who share your taste. Discuss books, share recommendations, and read together.
  </p>
</div>

<div class="max-w-7xl mx-auto px-4 pb-20">

  <!-- Flash messages -->
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="bg-green-50 border border-green-300 text-green-800 px-4 py-3
                rounded-lg mb-5 text-sm flex items-center gap-2 mt-6">
      <span>✓</span> <%= success_msg %>
    </div>
  <% } %>
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="bg-red-50 border border-red-300 text-red-800 px-4 py-3
                rounded-lg mb-5 text-sm flex items-center gap-2 mt-6">
      <span>✕</span> <%= error_msg %>
    </div>
  <% } %>

  <!-- Top bar: Search + Create -->
  <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center mt-7 mb-8">

    <!-- Search -->
    <form action="/communities" method="GET" class="flex-1">
      <div class="search-bar-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
        <input type="text" name="search" value="<%= search %>"
               placeholder="Search by name or genre…"
               class="search-input"/>
      </div>
    </form>

    <% if (search && search.length > 0) { %>
      <a href="/communities"
         class="flex-shrink-0 border border-amber-300 text-amber-700 hover:bg-amber-50
                text-sm font-semibold py-2.5 px-5 rounded-full transition-all duration-200 text-center">
        Clear
      </a>
    <% } %>

    <!-- Create button -->
    <% if (currentUser) { %>
      <button onclick="document.getElementById('create-modal').classList.add('open')"
              class="flex-shrink-0 bg-amber-700 hover:bg-amber-800 text-white font-semibold
                     py-2.5 px-6 rounded-full transition-all duration-200
                     shadow-md hover:shadow-lg hover:-translate-y-0.5 text-sm whitespace-nowrap">
        + Create Community
      </button>
    <% } %>
  </div>

  <!-- Results label -->
  <% if (search && search.length > 0) { %>
    <p class="text-amber-600 text-sm mb-6">
      <%= communities.length %> result<%= communities.length !== 1 ? 's' : '' %>
      for "<strong><%= search %></strong>"
    </p>
  <% } %>

  <!-- Communities grid -->
  <% if (communities.length === 0) { %>
    <div class="text-center py-20 text-amber-400">
      <p class="text-5xl mb-4">📚</p>
      <p class="font-serif text-xl text-amber-700">No communities found</p>
      <p class="text-sm mt-2">Try a different search or create one!</p>
    </div>
  <% } else { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% communities.forEach(community => { %>
      <div class="bg-white rounded-2xl overflow-hidden shadow-md
                  hover:shadow-xl transition-all duration-300
                  hover:-translate-y-1 border border-amber-50 flex flex-col">

        <!-- Cover image (shorter) -->
        <div class="comm-cover relative overflow-hidden flex-shrink-0">
          <img src="<%= community.coverImage %>"
               alt="<%= community.name %>"
               class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
               onerror="this.style.display='none'; this.parentElement.style.background='linear-gradient(135deg,#c9a96e,#8b6914)';" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>

          <!-- Genre badge -->
          <span class="absolute top-3 left-3 bg-white/90 text-amber-800
                       text-xs font-semibold px-2.5 py-1 rounded-full">
            <%= community.genre %>
          </span>

          <!-- Admin badge if user is admin -->
          <% if (currentUser && community.isAdmin) { %>
            <span class="absolute top-3 right-3 bg-amber-500 text-white
                         text-xs font-semibold px-2 py-1 rounded-full">
              Admin
            </span>
          <% } %>

          <!-- Name + members -->
          <div class="absolute bottom-0 left-0 right-0 px-4 pb-3">
            <h3 class="font-serif text-white font-bold text-base leading-tight drop-shadow-lg">
              <%= community.name %>
            </h3>
            <span class="text-white/80 text-xs flex items-center gap-1 mt-0.5">
              👥 <%= community.memberCount %> member<%= community.memberCount !== 1 ? 's' : '' %>
            </span>
          </div>
        </div>

        <!-- Card body -->
        <div class="p-4 flex flex-col flex-1">
          <p class="text-amber-700 text-sm leading-relaxed mb-4 flex-1 line-clamp-2">
            <%= community.description %>
          </p>

          <!-- Action buttons row -->
          <div class="flex gap-2">
            <% if (currentUser) { %>

              <!-- Open Chat (only if member) -->
              <% if (community.isJoined) { %>
                <button
                  onclick='openChat(<%= JSON.stringify({
                    id:          community._id,
                    name:        community.name,
                    cover:       community.coverImage,
                    memberCount: community.memberCount,
                    isAdmin:     community.isAdmin,
                    genre:       community.genre
                  }) %>)'
                  class="flex-1 bg-amber-700 hover:bg-amber-800 text-white font-semibold
                         py-2 px-3 rounded-full text-xs transition-all duration-200
                         shadow-md hover:-translate-y-0.5 flex items-center justify-center gap-1.5">
                  💬 Open Chat
                </button>
              <% } %>

              <!-- Join / Leave -->
              <form action="/communities/join/<%= community._id %>" method="POST"
                    class="<%= community.isJoined ? 'flex-shrink-0' : 'flex-1' %>">
                <button type="submit"
                  class="w-full font-semibold py-2 px-4 rounded-full text-xs
                         transition-all duration-200
                         <%= community.isJoined
                           ? 'border border-amber-200 text-amber-500 hover:bg-red-50 hover:border-red-300 hover:text-red-500'
                           : 'bg-amber-700 hover:bg-amber-800 text-white shadow-md hover:-translate-y-0.5' %>">
                  <%= community.isJoined ? 'Leave' : 'Join Community' %>
                </button>
              </form>

            <% } else { %>
              <a href="/auth/login"
                 class="flex-1 block text-center border border-amber-300 text-amber-700
                        hover:bg-amber-700 hover:text-white hover:border-amber-700
                        font-semibold py-2 px-4 rounded-full text-xs
                        transition-all duration-200">
                Login to Join
              </a>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
  <% } %>
</div>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- CREATE COMMUNITY MODAL                                  -->
<!-- ═══════════════════════════════════════════════════════ -->
<div id="create-modal"
     onclick="if(event.target===this) this.classList.remove('open')">
  <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md p-7 mx-4"
       onclick="event.stopPropagation()">

    <div class="flex items-center justify-between mb-5">
      <h2 class="font-serif text-2xl font-bold text-amber-900">Create a Community</h2>
      <button onclick="document.getElementById('create-modal').classList.remove('open')"
              class="text-amber-400 hover:text-amber-700 text-2xl leading-none">✕</button>
    </div>

    <form action="/communities/create" method="POST"
          enctype="multipart/form-data" class="space-y-4">

      <div>
        <label class="block text-sm font-medium text-amber-800 mb-1.5">Community Name</label>
        <input type="text" name="name" required maxlength="80"
               placeholder="e.g. Dark Romance Addicts"
               class="w-full px-4 py-3 border border-amber-200 rounded-xl
                      bg-amber-50/50 focus:outline-none focus:ring-2
                      focus:ring-amber-400 text-amber-900 text-sm"/>
      </div>

      <div>
        <label class="block text-sm font-medium text-amber-800 mb-1.5">Genre</label>
        <select name="genre" required
                class="w-full px-4 py-3 border border-amber-200 rounded-xl
                       bg-amber-50/50 focus:outline-none focus:ring-2
                       focus:ring-amber-400 text-amber-900 text-sm">
          <option value="">Select a genre…</option>
          <% ['Fantasy','Romance','Thriller','Mystery','Sci-Fi',
              'Horror','Historical','Non-Fiction','General'].forEach(g => { %>
            <option value="<%= g %>"><%= g %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-amber-800 mb-1.5">Description</label>
        <textarea name="description" required maxlength="500" rows="3"
                  placeholder="What's this community about?"
                  class="w-full px-4 py-3 border border-amber-200 rounded-xl
                         bg-amber-50/50 focus:outline-none focus:ring-2
                         focus:ring-amber-400 text-amber-900 resize-none text-sm"></textarea>
      </div>

      <!-- Cover image upload -->
      <div>
        <label class="block text-sm font-medium text-amber-800 mb-1.5">
          Cover Image <span class="text-amber-400 font-normal">(optional)</span>
        </label>
        <label for="cover-upload"
               class="flex items-center gap-3 px-4 py-3 border-2 border-dashed
                      border-amber-200 rounded-xl cursor-pointer hover:border-amber-400
                      hover:bg-amber-50/50 transition-all duration-200 group">
          <span class="text-2xl">🖼️</span>
          <div>
            <p class="text-sm font-medium text-amber-700 group-hover:text-amber-900">
              Click to upload a cover photo
            </p>
            <p class="text-xs text-amber-400">JPG, PNG, WebP — max 5MB</p>
          </div>
        </label>
        <input id="cover-upload" type="file" name="coverImage"
               accept="image/jpeg,image/jpg,image/png,image/webp"
               class="hidden" onchange="previewCover(this)"/>

        <!-- Preview -->
        <div id="cover-preview-wrap">
          <img id="cover-preview-img" src="" alt="Preview"/>
          <button type="button" onclick="clearCover()">✕</button>
        </div>
      </div>

      <div class="flex gap-3 pt-1">
        <button type="submit"
                class="flex-1 bg-amber-700 hover:bg-amber-800 text-white
                       font-semibold py-3 px-6 rounded-full transition-colors text-sm">
          Create Community
        </button>
        <button type="button"
                onclick="document.getElementById('create-modal').classList.remove('open')"
                class="flex-1 border-2 border-amber-300 text-amber-700
                       hover:bg-amber-50 font-semibold py-3 px-6
                       rounded-full transition-colors text-sm">
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- CHAT PANEL                                              -->
<!-- ═══════════════════════════════════════════════════════ -->
<div id="chat-panel" onclick="if(event.target===this) closeChat()">
  <div class="chat-box" onclick="event.stopPropagation()">

    <!-- Header -->
    <div class="chat-header">
      <img id="cp-cover" class="chat-header-img" src="" alt=""/>
      <div class="chat-header-info">
        <h3 id="cp-name">Community Name</h3>
        <p id="cp-meta">Loading…</p>
      </div>
      <button onclick="closeChat()"
              style="background:rgba(255,255,255,0.15); border:none; color:#fff;
                     width:32px; height:32px; border-radius:50%; cursor:pointer;
                     font-size:16px; display:flex; align-items:center; justify-content:center;">
        ✕
      </button>
    </div>

    <!-- Body: messages + sidebar -->
    <div class="chat-body">

      <!-- Messages -->
      <div id="cp-messages" class="chat-messages">
        <div class="chat-empty">
          <span style="font-size:2rem;">💬</span>
          <p>Loading messages…</p>
        </div>
      </div>

      <!-- Members sidebar -->
      <div class="chat-sidebar">
        <div class="sidebar-title">Members</div>
        <div id="cp-members" class="sidebar-members"></div>
        <div id="cp-admin-actions" class="sidebar-actions" style="display:none;">
          <form id="delete-community-form" method="POST">
            <button type="button" class="delete-btn"
                    onclick="confirmDelete()">
              🗑 Delete Community
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Input bar -->
    <div class="chat-input-bar" id="cp-input-bar">
      <textarea id="cp-input" placeholder="Type a message…" rows="1"
                onkeydown="handleChatKey(event)"
                oninput="autoResizeTextarea(this)"></textarea>
      <button class="chat-send-btn" onclick="sendMessage()">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </button>
    </div>

    <!-- Non-member notice -->
    <div id="cp-join-notice"
         style="display:none; padding:12px 16px; background:#fef3c7;
                text-align:center; font-size:12px; color:#92400e; flex-shrink:0;">
      Join this community to send messages.
    </div>

  </div>
</div>

<script>
// ── Current user info (passed from server) ────────────────────────────────────
const CURRENT_USER_ID   = '<%= currentUser ? currentUser._id : "" %>';
const CURRENT_USER_NAME = '<%= currentUser ? currentUser.name.replace(/'/g, "\\'") : "" %>';

// ── Active community state ────────────────────────────────────────────────────
let activeCommunity = null;
let pollTimer       = null;

// ── Open chat ─────────────────────────────────────────────────────────────────
function openChat(community) {
  activeCommunity = community;

  // Update header
  const cover = community.cover || `/images/genres/${community.genre.toLowerCase()}.jpg`;
  document.getElementById('cp-cover').src = cover;
  document.getElementById('cp-cover').onerror = function() {
    this.src = '/images/fallback-cover.jpg';
  };
  document.getElementById('cp-name').textContent = community.name;
  document.getElementById('cp-meta').textContent = `${community.memberCount} members · ${community.genre}`;

  // Show/hide admin actions
  document.getElementById('cp-admin-actions').style.display = community.isAdmin ? 'block' : 'none';

  // Set delete form action
  document.getElementById('delete-community-form').action = `/communities/${community.id}/delete`;

  // Open panel
  document.getElementById('chat-panel').classList.add('open');
  document.body.style.overflow = 'hidden';

  // Load messages
  loadMessages(true);

  // Poll every 4 seconds
  clearInterval(pollTimer);
  pollTimer = setInterval(() => loadMessages(false), 4000);
}

function closeChat() {
  document.getElementById('chat-panel').classList.remove('open');
  document.body.style.overflow = '';
  clearInterval(pollTimer);
  activeCommunity = null;
}

// ── Load messages via fetch ───────────────────────────────────────────────────
async function loadMessages(scroll) {
  if (!activeCommunity) return;
  try {
    const res  = await fetch(`/communities/${activeCommunity.id}/messages`);
    const data = await res.json();
    if (!data.ok) return;

    renderMessages(data.messages, scroll);
    renderMembers(data.members, data.admins, data.creatorId);
  } catch (e) {
    console.error('Poll error', e);
  }
}

// ── Render messages ───────────────────────────────────────────────────────────
function renderMessages(messages, scroll) {
  const container = document.getElementById('cp-messages');

  if (!messages.length) {
    container.innerHTML = `
      <div class="chat-empty">
        <span style="font-size:2rem;">📖</span>
        <p>No messages yet. Be the first to say something!</p>
      </div>`;
    return;
  }

  const prevScrollBottom = container.scrollHeight - container.scrollTop;

  container.innerHTML = messages.map(msg => {
    const mine    = msg.authorId === CURRENT_USER_ID;
    const initials = msg.authorName ? msg.authorName.charAt(0).toUpperCase() : '?';
    const time    = new Date(msg.createdAt).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});

    return `
      <div class="msg-row ${mine ? 'mine' : 'other'}">
        <div class="msg-avatar">${initials}</div>
        <div style="flex:1;min-width:0;">
          ${!mine ? `<div class="msg-author">${escHtml(msg.authorName)}</div>` : ''}
          <div class="msg-bubble">${escHtml(msg.content)}</div>
          <div class="msg-meta">${time}</div>
        </div>
      </div>`;
  }).join('');

  if (scroll) {
    container.scrollTop = container.scrollHeight;
  } else {
    // Auto-scroll only if user was already near the bottom
    const isNearBottom = prevScrollBottom < 200;
    if (isNearBottom) container.scrollTop = container.scrollHeight;
  }
}

// ── Render members sidebar ────────────────────────────────────────────────────
function renderMembers(members, admins, creatorId) {
  const container = document.getElementById('cp-members');
  const isAdmin   = activeCommunity && activeCommunity.isAdmin;

  container.innerHTML = members.map(m => {
    const initials  = m.name ? m.name.charAt(0).toUpperCase() : '?';
    const isCreator = m.id === creatorId;
    const isAdm     = admins.includes(m.id);
    const canRemove = isAdmin && !isCreator && m.id !== CURRENT_USER_ID;

    return `
      <div class="member-row">
        <div class="member-avatar">${initials}</div>
        <span class="member-name">${escHtml(m.name)}</span>
        ${isCreator ? '<span class="admin-badge">Owner</span>' :
          isAdm     ? '<span class="admin-badge">Admin</span>' : ''}
        ${canRemove ? `
          <form method="POST" action="/communities/${activeCommunity.id}/remove-member"
                style="display:inline;">
            <input type="hidden" name="memberId" value="${m.id}"/>
            <button type="submit" class="remove-btn"
                    onclick="return confirm('Remove ${escHtml(m.name)}?')">✕</button>
          </form>` : ''}
      </div>`;
  }).join('');
}

// ── Send message ──────────────────────────────────────────────────────────────
async function sendMessage() {
  const input   = document.getElementById('cp-input');
  const content = input.value.trim();
  if (!content || !activeCommunity) return;

  input.value = '';
  input.style.height = '';

  try {
    const res = await fetch(`/communities/${activeCommunity.id}/chat`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content })
    });
    const data = await res.json();
    if (data.ok) {
      renderMessages(data.messages, true);
    }
  } catch (e) {
    console.error('Send error', e);
  }
}

function handleChatKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function autoResizeTextarea(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 80) + 'px';
}

// ── Confirm + delete ──────────────────────────────────────────────────────────
function confirmDelete() {
  if (confirm(`Delete "${activeCommunity.name}"? This cannot be undone.`)) {
    document.getElementById('delete-community-form').submit();
  }
}

// ── Escape HTML ───────────────────────────────────────────────────────────────
function escHtml(str) {
  if (!str) return '';
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

// ── Cover image preview ───────────────────────────────────────────────────────
function previewCover(input) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('cover-preview-img').src = e.target.result;
    document.getElementById('cover-preview-wrap').style.display = 'block';
  };
  reader.readAsDataURL(input.files[0]);
}

function clearCover() {
  document.getElementById('cover-upload').value = '';
  document.getElementById('cover-preview-wrap').style.display = 'none';
  document.getElementById('cover-preview-img').src = '';
}

// ── Keyboard close ────────────────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    closeChat();
    document.getElementById('create-modal').classList.remove('open');
  }
});
</script>

<%- include('../partials/footer') %>
</body>
</html>