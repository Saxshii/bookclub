<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
</head>
<body class="bg-cream min-h-screen">

  <%- include('../partials/navbar') %>

  <!-- Header -->
  <div class="pt-28 pb-12 px-4 bg-gradient-to-b from-amber-50 to-cream text-center">
    <p class="text-amber-500 text-xs tracking-widest uppercase mb-2">Find your people</p>
    <h1 class="font-serif text-5xl font-bold text-amber-900 mb-3">Reading Communities</h1>
    <p class="text-amber-600 max-w-xl mx-auto">
      Join groups of readers who share your taste. Discuss books, share recommendations,
      and read together.
    </p>
  </div>

  <div class="max-w-7xl mx-auto px-4 pb-20">

    <!-- Flash messages -->
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="flash-success mb-6"><span>✓</span> <%= success_msg %></div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="flash-error mb-6"><span>✕</span> <%= error_msg %></div>
    <% } %>

    <!-- Create community button -->
    <% if (currentUser) { %>
      <div class="flex justify-end mb-6">
        <button onclick="document.getElementById('create-modal').classList.remove('hidden')"
                class="btn-primary">
          + Create Community
        </button>
      </div>
    <% } %>

    <!-- Communities grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% communities.forEach(community => { %>
        <div class="bg-white rounded-2xl overflow-hidden shadow-warm
                    hover:shadow-warm-lg transition-all duration-300
                    hover:-translate-y-1 border border-amber-50">

          <!-- Cover image -->
          <div class="relative h-36 overflow-hidden">
            <img src="<%= community.coverImage %>"
                 alt="<%= community.name %>"
                 class="w-full h-full object-cover"
                 onerror="this.style.background='linear-gradient(135deg,#c9a96e,#8b6914)'"/>
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>

            <!-- Genre badge -->
            <span class="absolute top-3 left-3 bg-white/90 text-amber-800
                         text-xs font-semibold px-2.5 py-1 rounded-full">
              <%= community.genre %>
            </span>

            <!-- Member count -->
            <span class="absolute bottom-3 right-3 text-white text-xs">
              👥 <%= community.memberCount %> members
            </span>
          </div>

          <!-- Content -->
          <div class="p-5">
            <h3 class="font-serif text-lg font-semibold text-amber-900 mb-2">
              <%= community.name %>
            </h3>
            <p class="text-amber-700 text-sm leading-relaxed mb-5 line-clamp-3">
              <%= community.description %>
            </p>

            <!-- Join / Leave button -->
            <% if (currentUser) { %>
              <form action="/communities/join/<%= community._id %>" method="POST">
                <button type="submit"
                        class="w-full <%= community.isJoined
                          ? 'border-2 border-amber-300 text-amber-600 hover:bg-red-50 hover:border-red-300 hover:text-red-600'
                          : 'btn-primary' %>
                          font-semibold py-2 px-4 rounded-full text-sm transition-all duration-200">
                  <%= community.isJoined ? '✓ Joined — Leave' : 'Join Community' %>
                </button>
              </form>
            <% } else { %>
              <a href="/auth/login"
                 class="block text-center btn-secondary text-sm py-2">
                Login to Join
              </a>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>

  </div>

  <!-- ── Create Community Modal ─────────────────────────────────────────────── -->
  <div id="create-modal"
       class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden"
       style="background: rgba(44,24,16,0.7); backdrop-filter: blur(4px);">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-serif text-2xl font-bold text-amber-900">Create a Community</h2>
        <button onclick="document.getElementById('create-modal').classList.add('hidden')"
                class="text-amber-400 hover:text-amber-700 text-2xl leading-none">✕</button>
      </div>

      <form action="/communities/create" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-amber-800 mb-1.5">
            Community Name
          </label>
          <input type="text" name="name" required maxlength="80"
                 placeholder="e.g. Dark Romance Addicts"
                 class="form-input"/>
        </div>

        <div>
          <label class="block text-sm font-medium text-amber-800 mb-1.5">Genre</label>
          <select name="genre" required class="form-input">
            <option value="">Select a genre...</option>
            <% ['Fantasy','Romance','Thriller','Mystery','Sci-Fi','Horror','Historical','Non-Fiction','General'].forEach(g => { %>
              <option value="<%= g %>"><%= g %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-amber-800 mb-1.5">Description</label>
          <textarea name="description" required maxlength="300" rows="3"
                    placeholder="What's this community about?"
                    class="form-input resize-none"></textarea>
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" class="btn-primary flex-1">Create Community</button>
          <button type="button"
                  onclick="document.getElementById('create-modal').classList.add('hidden')"
                  class="btn-secondary flex-1">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>