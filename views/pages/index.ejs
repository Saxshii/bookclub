<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/css/output.css" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap"
    rel="stylesheet" />
  <style>
    .hero-bg {
      background-image: url('/images/hero-bg.jpg');
      background-size: cover;
      background-position: center top;
      background-attachment: fixed;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes float {

      0%,
      100% {
        transform: translateY(0px);
      }

      50% {
        transform: translateY(-8px);
      }
    }

    @keyframes scrollLeft {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(-50%);
      }
    }

    @keyframes shimmer {
      0% {
        background-position: -200% center;
      }

      100% {
        background-position: 200% center;
      }
    }

    .animate-fade-up {
      animation: fadeInUp 0.8s ease forwards;
      opacity: 0;
    }

    .animate-float {
      animation: float 3s ease-in-out infinite;
    }

    .carousel-track {
      animation: scrollLeft 6s linear infinite;
    }

    .carousel-track:hover {
      animation: paused;
    }

    .section-divider {
      height: 1px;
      background: linear-gradient(to right, transparent, #c9a96e66, #c9a96e, #c9a96e66, transparent);
    }

    .shimmer-text {
      background: linear-gradient(90deg, #f5deb3, #c9a96e, #f5deb3, #e8c87a, #f5deb3);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 4s linear infinite;
    }

    .genre-card-hover {
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .genre-card-hover:hover {
      transform: translateY(-8px) scale(1.02);
    }

    .community-card {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(250, 247, 242, 0.98));
      border: 1px solid rgba(201, 169, 110, 0.2);
      transition: all 0.3s ease;
    }

    .community-card:hover {
      transform: translateY(-4px);
      border-color: rgba(201, 169, 110, 0.5);
      box-shadow: 0 20px 40px rgba(139, 105, 20, 0.15);
    }

    /* Section heading decorative line */
    .heading-line::after {
      content: '';
      display: block;
      width: 60px;
      height: 3px;
      background: linear-gradient(to right, #c9a96e, #8b6914);
      margin: 12px auto 0;
      border-radius: 2px;
    }

    .btn-glass {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.35);
      transition: all 0.3s ease;
    }

    .btn-glass:hover {
      background: rgba(255, 255, 255, 0.2);
      border-color: rgba(255, 255, 255, 0.6);
      transform: translateY(-2px);
    }
  </style>
</head>

<body class="bg-cream min-h-screen">

  <%- include('../partials/navbar') %>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- HERO SECTION                                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <section class="hero-bg min-h-screen flex items-center justify-center relative overflow-hidden pt-16">

      <!-- Layered overlay -->
      <div class="absolute inset-0" style="background: linear-gradient(
      to bottom,
      rgba(8, 4, 2, 0.50) 0%,
      rgba(8, 4, 2, 0.30) 35%,
      rgba(8, 4, 2, 0.55) 70%,
      rgba(8, 4, 2, 0.82) 100%
    );"></div>

      <!-- Content pushed left so bookshelf on right shows -->
      <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-16
                flex flex-col items-start justify-center min-h-screen pb-24">

        <!-- Eyebrow label -->
        <div class="animate-fade-up flex items-center gap-3 mb-6" style="animation-delay: 0.1s;">
          <div class="h-px w-8 bg-amber-400/70"></div>
          <p class="text-amber-400 text-xs font-medium tracking-[0.3em] uppercase"
            style="text-shadow: 0 1px 8px rgba(0,0,0,0.9);">
            Welcome to your virtual library
          </p>
          <div class="h-px w-8 bg-amber-400/70"></div>
        </div>

        <!-- Main headline -->
        <h1 class="animate-fade-up font-serif font-bold text-white leading-[1.1] mb-6" style="animation-delay: 0.25s;
                 font-size: clamp(3rem, 6.5vw, 5.8rem);
                 text-shadow: 0 2px 24px rgba(0,0,0,0.8);">
          Where Every Story<br />
          <span class="shimmer-text italic">Finds Its Reader</span>
        </h1>

        <!-- Subtext -->
        <p class="animate-fade-up leading-relaxed mb-10 max-w-lg" style="animation-delay: 0.4s;
                font-size: clamp(1rem, 1.5vw, 1.15rem);
                color: rgba(255,255,255,0.82);
                text-shadow: 0 1px 16px rgba(0,0,0,0.95);">
          Discover books tailored to your taste, organize your personal shelf,
          and connect with readers who love what you love.
        </p>

        <!-- Buttons -->
        <div class="animate-fade-up flex flex-col sm:flex-row gap-4" style="animation-delay: 0.55s;">

          <a href="/explore" class="group inline-flex items-center justify-center gap-2
                  bg-amber-600 hover:bg-amber-500 text-white font-semibold
                  py-3.5 px-9 rounded-full shadow-lg hover:shadow-amber-600/40
                  transition-all duration-300 hover:-translate-y-0.5 text-base">
            Explore Books
            <span class="group-hover:translate-x-1.5 transition-transform duration-300 text-lg">→</span>
          </a>

          <% if (currentUser) { %>
            <a href="/books/bookshelf" class="btn-glass inline-flex items-center justify-center gap-2
                    text-white font-semibold py-3.5 px-9 rounded-full text-base">
              📚 My Bookshelf
            </a>
            <% } else { %>
              <a href="/auth/signup" class="btn-glass inline-flex items-center justify-center gap-2
                    text-white font-semibold py-3.5 px-9 rounded-full text-base">
                Join Free ✨
              </a>
              <% } %>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2
                  flex flex-col items-center gap-2 animate-fade-up" style="animation-delay: 1.2s;">
          <span class="text-white/30 text-xs tracking-[0.3em] uppercase">Scroll</span>
          <div class="w-px h-10 bg-gradient-to-b from-white/30 to-transparent animate-float"></div>
        </div>

      </div>

      <!-- Bottom wave into next section -->
      <div class="absolute bottom-0 left-0 right-0">
        <svg viewBox="0 0 1440 70" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0,70 C360,10 1080,10 1440,70 L1440,70 L0,70 Z" fill="#faf7f2" />
        </svg>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- BOOK CAROUSEL                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <section class="py-20 bg-cream overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 mb-12 text-center">
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-amber-900 heading-line">
          Popular Novels
        </h2>
      </div>

      <div class="relative overflow-hidden">

        <!-- Left fade -->
        <div class="absolute left-0 top-0 bottom-0 w-32 z-10 pointer-events-none"
          style="background: linear-gradient(to right, #faf7f2 10%, transparent)">
        </div>
        <!-- Right fade -->
        <div class="absolute right-0 top-0 bottom-0 w-32 z-10 pointer-events-none"
          style="background: linear-gradient(to left, #faf7f2 10%, transparent)">
        </div>

        <!-- Scrolling track -->
        <div class="carousel-track flex gap-7 w-max px-10">
          <% const allBooks=[...carouselBooks, ...carouselBooks]; %>
            <% allBooks.forEach(book=> { %>

              <div class="flex-shrink-0 w-48 group cursor-pointer">

                <!-- Cover card -->
                <div class="relative overflow-hidden rounded-2xl shadow-xl
                      group-hover:shadow-2xl transition-all duration-500
                      group-hover:-translate-y-5 group-hover:scale-[1.04]" style="height: 290px;
                      background: linear-gradient(135deg, #3d1f0a 0%, #8b6914 100%);">

                  <img src="<%= book.coverUrl %>" alt="<%= book.title %>" class="w-full h-full object-cover transition-transform
                     duration-700 group-hover:scale-105" onerror="this.style.display='none'" />

                  <!-- Bottom hover overlay -->
                  <div class="absolute inset-0 bg-gradient-to-t
                        from-black/90 via-black/30 to-transparent
                        opacity-0 group-hover:opacity-100
                        transition-opacity duration-300
                        flex flex-col justify-end p-4">
                    <p class="text-white text-sm font-bold leading-tight
                         line-clamp-2 mb-1 font-serif">
                      <%= book.title %>
                    </p>
                    <p class="text-amber-300 text-xs">
                      <%= book.author %>
                    </p>
                  </div>

                  <!-- Top shine -->
                  <div class="absolute inset-0 opacity-0 group-hover:opacity-100
                        transition-opacity duration-500 pointer-events-none" style="background: linear-gradient(135deg,
                   rgba(255,255,255,0.1) 0%,
                   transparent 55%)">
                  </div>

                </div>

                <!-- Title below -->
                <div class="mt-3 px-1">
                  <p class="font-serif text-sm font-semibold text-amber-900
                      line-clamp-1 group-hover:text-amber-600
                      transition-colors duration-200">
                    <%= book.title %>
                  </p>
                  <p class="text-amber-500 text-xs mt-0.5 line-clamp-1">
                    <%= book.author %>
                  </p>
                </div>

              </div>

              <% }) %>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- EXPLORE GENRES                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">

        <div class="text-center mb-14">
          <h2 class="font-serif text-4xl md:text-5xl font-bold text-amber-900 heading-line">
            Explore Genres
          </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          <% genres.forEach(genre=> { %>
            <a href="/genre/<%= genre.slug %>" class="genre-card-hover relative rounded-2xl overflow-hidden
                    cursor-pointer shadow-lg" style="height: 210px;">

              <div class="absolute inset-0">
                <img src="<%= genre.bgImage %>" alt="<%= genre.name %>" class="w-full h-full object-cover transition-transform duration-700
                          hover:scale-110" onerror="this.style.background='linear-gradient(135deg,#4a2040,#1a0a2e)'" />
              </div>

              <div class="absolute inset-0 bg-gradient-to-t
                        from-black/85 via-black/35 to-black/10"></div>

              <div class="absolute bottom-0 left-0 right-0 p-4 text-white">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-2xl">
                    <%= genre.emoji %>
                  </span>
                  <h3 class="font-serif text-lg font-bold">
                    <%= genre.name %>
                  </h3>
                </div>
                <p class="text-white/65 text-xs leading-snug line-clamp-2">
                  <%= genre.description %>
                </p>
              </div>

              <div class="absolute inset-0 rounded-2xl ring-2 ring-transparent
                        hover:ring-amber-400/70 transition-all duration-300"></div>
            </a>
            <% }) %>
        </div>

        <div class="text-center mt-10">
          <a href="/explore" class="inline-flex items-center gap-2 btn-secondary
                  hover:gap-3 transition-all duration-200">
            Browse All Genres <span>→</span>
          </a>
        </div>
      </div>
    </section>

    <div class="section-divider max-w-5xl mx-auto my-4"></div>


    <!-- YOUR 
   SHELF -->

    <section class="py-10 px-4">
      <div class="max-w-6xl mx-auto">

        <div class="relative rounded-3xl overflow-hidden shadow-lg bg-cover bg-center min-h-[500px]"
          style="background-image: url('/images/div-bg.jpg');">

          <!-- Overlay -->
          <div class="absolute inset-0 bg-black/50"></div>

          <div class="relative z-10 flex items-center h-full">

            <div class="p-10 md:p-14 max-w-xl flex flex-col justify-center h-full">

              <h2 class="text-4xl md:text-5xl font-bold text-white mb-5 leading-tight">
                Build Your<br />Dream Bookshelf
              </h2>

              <p class="text-gray-200 mb-8">
                Save books you love, track your reading progress, and keep all your notes and reviews — in one cozy
                digital shelf.
              </p>

              <div class="flex gap-4">
                <a href="/auth/signup" class="bg-yellow-400 text-black font-bold py-3 px-6 rounded-full">
                  Let's build your Shelf
                </a>

                <a href="/auth/login"
                  class="border border-white text-white py-3 px-6 rounded-full hover:bg-white hover:text-black">
                  Login
                </a>
              </div>

            </div>

          </div>
        </div>

      </div>
    </section>

    <div class="section-divider max-w-5xl mx-auto my-4"></div>


    <!-- COMMUNITIES                                                             -->

    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">

        <div class="text-center mb-14">
          <h2 class="font-serif text-4xl md:text-5xl font-bold text-amber-900 heading-line">
            Reading Communities
          </h2>
          <p class="text-amber-700 mt-5 max-w-lg mx-auto text-base leading-relaxed">
            Find your people.Join communities built around the books and genres you love most.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <% featuredCommunities.forEach(community=> { %>
            <div class="community-card rounded-2xl p-6 shadow-warm">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center
                        bg-amber-100 text-2xl mb-4 shadow-sm">
                <%= community.emoji %>
              </div>
              <h3 class="font-serif text-lg font-semibold text-amber-900 mb-1">
                <%= community.name %>
              </h3>
              <p class="text-xs text-amber-500 mb-3 flex items-center gap-1">
                <span>👥</span>
                <%= community.members.toLocaleString() %> members · <%= community.genre %>
              </p>
              <p class="text-amber-700 text-sm leading-relaxed mb-5">
                <%= community.description %>
              </p>
              <a href="/communities" class="block text-center border border-amber-300 text-amber-700
                      hover:bg-amber-700 hover:text-white hover:border-amber-700
                      font-semibold py-2 px-4 rounded-full text-sm
                      transition-all duration-200">
                Join Community
              </a>
            </div>
            <% }) %>
        </div>

        <div class="text-center mt-12">
          <a href="/communities" class="inline-flex items-center gap-2 btn-primary text-base
                  hover:gap-3 transition-all duration-200">
            See All Communities →
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- FOOTER CTA BANNER                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <% if (!currentUser) { %>
      <section class="py-16 px-4 bg-amber-50 border-t border-amber-100">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-5xl mb-4">📚</p>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-amber-900 mb-4">
            Ready to start your reading journey?
          </h2>
          <p class="text-amber-700 mb-8 max-w-md mx-auto">
            Join BookClub for free and get access to millions of books,
            personal shelves, and a community of readers.
          </p>
          <a href="/auth/signup" class="btn-primary text-base py-3.5 px-10">
            Create Free Account →
          </a>
        </div>
      </section>
      <% } %>

        <%- include('../partials/footer') %>

</body>

</html>