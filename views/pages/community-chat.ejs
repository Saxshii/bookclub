<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #f5ede0;
      font-family: 'Lato', sans-serif;
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── Top bar ── */
    .chat-topbar {
      background: linear-gradient(135deg, #5c2a06 0%, #9b4a12 100%);
      color: #fff;
      padding: 0 20px;
      height: 64px;
      display: flex;
      align-items: center;
      gap: 14px;
      flex-shrink: 0;
      box-shadow: 0 2px 12px rgba(0,0,0,0.25);
      z-index: 10;
    }

    .back-btn {
      background: rgba(255,255,255,0.15);
      border: none;
      color: #fff;
      width: 36px; height: 36px;
      border-radius: 50%;
      font-size: 18px;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
      flex-shrink: 0;
      text-decoration: none;
    }
    .back-btn:hover { background: rgba(255,255,255,0.25); }

    .topbar-cover {
      width: 40px; height: 40px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid rgba(255,255,255,0.35);
      flex-shrink: 0;
    }

    .topbar-info { flex: 1; min-width: 0; }
    .topbar-info h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1rem; font-weight: 700;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .topbar-info p { font-size: 11px; opacity: 0.75; margin-top: 1px; }

    .topbar-actions { display: flex; gap: 8px; flex-shrink: 0; }
    .topbar-icon-btn {
      background: rgba(255,255,255,0.12);
      border: none; color: #fff;
      width: 36px; height: 36px;
      border-radius: 50%; cursor: pointer; font-size: 16px;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
      position: relative;
    }
    .topbar-icon-btn:hover { background: rgba(255,255,255,0.25); }

    /* members dropdown */
    .members-dropdown {
      position: absolute; top: 44px; right: 0;
      width: 220px;
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.18);
      padding: 8px 0;
      display: none;
      z-index: 100;
    }
    .members-dropdown.open { display: block; }
    .dropdown-header {
      padding: 8px 16px 6px;
      font-size: 10px;
      font-weight: 700;
      color: #9b4a12;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-bottom: 1px solid #f5e8d8;
      margin-bottom: 4px;
    }
    .dropdown-member {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 16px;
      font-size: 13px;
      color: #3d1f08;
    }
    .dropdown-avatar {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: linear-gradient(135deg, #c9a96e, #8b6914);
      color: #fff; font-size: 11px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .dropdown-name { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .badge {
      font-size: 9px; padding: 1px 6px; border-radius: 999px; font-weight: 700;
    }
    .badge-owner { background: #fef3c7; color: #92400e; }
    .badge-admin { background: #dbeafe; color: #1e40af; }

    .remove-member-form { display: inline; }
    .remove-member-btn {
      font-size: 11px; color: #ef4444;
      background: none; border: none; cursor: pointer;
      padding: 2px 4px; border-radius: 4px;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .dropdown-member:hover .remove-member-btn { opacity: 1; }

    /* admin panel at bottom of dropdown */
    .dropdown-admin-section {
      border-top: 1px solid #f5e8d8;
      margin-top: 4px;
      padding: 8px 12px;
    }
    .delete-community-btn {
      width: 100%;
      padding: 8px 0;
      background: #fff0f0;
      color: #dc2626;
      border: 1.5px solid #fca5a5;
      border-radius: 999px;
      font-size: 11px; font-weight: 700;
      cursor: pointer;
      transition: background 0.2s;
    }
    .delete-community-btn:hover { background: #fee2e2; }

    /* ── Main layout: messages + input ── */
    .chat-layout {
      flex: 1;
      display: flex;
      min-height: 0;
      overflow: hidden;
    }

    .chat-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
      background: #faf5ee;
      background-image:
        radial-gradient(circle at 20% 50%, rgba(201,169,110,0.06) 0%, transparent 50%),
        radial-gradient(circle at 80% 20%, rgba(139,105,20,0.04) 0%, transparent 40%);
    }

    /* ── Flash messages ── */
    .flash-bar {
      padding: 0 16px;
      flex-shrink: 0;
    }
    .flash-msg {
      display: flex; align-items: center; gap-8px;
      padding: 10px 14px;
      border-radius: 10px;
      font-size: 13px;
      margin-top: 10px;
      animation: slideDown 0.3s ease;
    }
    .flash-success { background: #f0fdf4; border: 1px solid #86efac; color: #166534; }
    .flash-error   { background: #fff0f0; border: 1px solid #fca5a5; color: #dc2626; }
    @keyframes slideDown { from { opacity:0; transform:translateY(-8px); } to { opacity:1; transform:translateY(0); } }

    /* ── Messages ── */
    .messages-area {
      flex: 1;
      overflow-y: auto;
      padding: 20px 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .messages-area::-webkit-scrollbar { width: 4px; }
    .messages-area::-webkit-scrollbar-thumb { background: #c9a96e44; border-radius: 4px; }

    /* date divider */
    .date-divider {
      text-align: center;
      font-size: 11px;
      color: #a8845a;
      margin: 8px 0;
      display: flex; align-items: center; gap: 12px;
    }
    .date-divider::before,
    .date-divider::after {
      content: ''; flex: 1; height: 1px; background: #e8d5b766;
    }

    .msg-row {
      display: flex;
      gap: 8px;
      max-width: 68%;
    }
    .msg-row.mine  { align-self: flex-end;   flex-direction: row-reverse; }
    .msg-row.other { align-self: flex-start; }

    .msg-avatar {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, #c9a96e, #7a4a14);
      color: #fff; font-size: 12px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; margin-top: 2px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.12);
    }

    .msg-content { flex: 1; min-width: 0; }
    .msg-author-name {
      font-size: 10px; font-weight: 700; color: #9b4a12;
      margin-bottom: 3px; padding-left: 2px;
    }
    .msg-bubble {
      padding: 9px 13px;
      border-radius: 18px;
      font-size: 13.5px;
      line-height: 1.55;
      word-break: break-word;
      display: inline-block;
      max-width: 100%;
    }
    .msg-row.mine  .msg-bubble {
      background: linear-gradient(135deg, #7a3a0a, #b8601a);
      color: #fff;
      border-bottom-right-radius: 5px;
      box-shadow: 0 2px 8px rgba(122,58,10,0.25);
    }
    .msg-row.other .msg-bubble {
      background: #fff;
      color: #2d1206;
      border-bottom-left-radius: 5px;
      box-shadow: 0 1px 5px rgba(0,0,0,0.09);
    }
    .msg-time {
      font-size: 10px; opacity: 0.5;
      margin-top: 3px; padding: 0 2px;
    }
    .msg-row.mine  .msg-time { text-align: right; }
    .msg-row.other .msg-time { text-align: left; }

    /* empty state */
    .empty-chat {
      flex: 1;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 10px; color: #c9a96e; text-align: center; padding: 40px;
    }
    .empty-chat p { font-size: 14px; color: #a8845a; }

    /* ── Input bar ── */
    .input-bar {
      padding: 12px 16px;
      background: #fff;
      border-top: 1px solid #eddfc8;
      display: flex;
      align-items: flex-end;
      gap: 10px;
      flex-shrink: 0;
    }
    .input-bar form {
      display: flex; width: 100%; gap: 10px; align-items: flex-end;
    }
    .msg-input {
      flex: 1;
      border: 1.5px solid #e0cdb0;
      border-radius: 22px;
      padding: 10px 16px;
      font-size: 14px;
      font-family: 'Lato', sans-serif;
      color: #2d1206;
      background: #faf7f2;
      resize: none;
      outline: none;
      line-height: 1.5;
      max-height: 100px;
      transition: border-color 0.2s;
    }
    .msg-input:focus { border-color: #9b4a12; }

    .send-btn {
      width: 42px; height: 42px;
      border-radius: 50%;
      background: linear-gradient(135deg, #7a3a0a, #b8601a);
      border: none; cursor: pointer; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 3px 10px rgba(122,58,10,0.35);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .send-btn:hover { transform: scale(1.08); box-shadow: 0 4px 14px rgba(122,58,10,0.45); }
    .send-btn svg { width: 17px; height: 17px; fill: #fff; }
  </style>
</head>
<body>
<% const avatarColors = [
  '#7a3a0a','#1d6a3a','#1a3a7a','#6a1a5a','#4a6a1a',
  '#7a1a1a','#1a5a6a','#5a3a7a','#6a4a1a','#1a6a5a'
]; %>

  <!-- ── Top bar ─────────────────────────────────────────────────────────── -->
  <div class="chat-topbar">
    <a href="/communities" class="back-btn" title="Back to communities">←</a>

    <img class="topbar-cover"
         src="<%= community.coverImage || '/images/genres/' + community.genre.toLowerCase() + '.jpg' %>"
         alt="<%= community.name %>"
         onerror="this.src='/images/fallback-cover.jpg'"/>

    <div class="topbar-info">
      <h1><%= community.name %></h1>
      <p><%= community.members.length %> member<%= community.members.length !== 1 ? 's' : '' %> · <%= community.genre %></p>
    </div>

    <!-- Members icon button -->
    <div class="topbar-actions">
      <% if (isAdmin) { %>
        <a href="/communities/<%= community._id %>/edit"
           class="topbar-icon-btn" title="Edit Community">✏️</a>
      <% } %>
      <div style="position:relative;">
        <button class="topbar-icon-btn" id="members-btn" title="Members"
                onclick="toggleMembers(event)">
          👥
        </button>

        <!-- Members dropdown -->
        <div class="members-dropdown" id="members-dropdown">
          <div class="dropdown-header">
            <%= community.members.length %> Member<%= community.members.length !== 1 ? 's' : '' %>
          </div>

          <% community.members.forEach(member => {
            const creatorId = community.createdBy ? (community.createdBy._id || community.createdBy).toString() : '';
            const isCreator = member._id.toString() === creatorId;
            const isAdminMember = community.admins.some(a => (a._id || a).toString() === member._id.toString());
            const canRemove = isAdmin && !isCreator && member._id.toString() !== userId;
            const mColorSeed = parseInt(member._id.toString().slice(-4), 16) % avatarColors.length;
          %>
            <div class="dropdown-member">
              <div class="dropdown-avatar" style="background:<%= avatarColors[mColorSeed] %>">
                <%= member.name.charAt(0).toUpperCase() %>
              </div>
              <span class="dropdown-name"><%= member.name %></span>
              <% if (isCreator) { %>
                <span class="badge badge-owner">Owner</span>
              <% } else if (isAdminMember) { %>
                <span class="badge badge-admin">Admin</span>
              <% } %>
              <% if (canRemove) { %>
                <form class="remove-member-form"
                      action="/communities/<%= community._id %>/remove-member"
                      method="POST"
                      onsubmit="return confirm('Remove <%= member.name %>?')">
                  <input type="hidden" name="memberId" value="<%= member._id %>"/>
                  <button type="submit" class="remove-member-btn">✕</button>
                </form>
              <% } %>
            </div>
          <% }) %>

          <% if (isAdmin) { %>
            <div class="dropdown-admin-section">
              <form action="/communities/<%= community._id %>/delete" method="POST"
                    onsubmit="return confirm('Delete <%= community.name %>? This cannot be undone.')">
                <button type="submit" class="delete-community-btn">🗑 Delete Community</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Chat layout ────────────────────────────────────────────────────── -->
  <div class="chat-layout">
    <div class="chat-main">

      <!-- Flash messages (auto-dismiss) -->
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flash-bar">
          <div class="flash-msg flash-success" id="flash-success">
            ✓ <%= success_msg %>
          </div>
        </div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="flash-bar">
          <div class="flash-msg flash-error" id="flash-error">
            ✕ <%= error_msg %>
          </div>
        </div>
      <% } %>

      <!-- Messages -->
      <div class="messages-area" id="messages-area">
          <% if (community.messages.length === 0) { %>
          <div class="empty-chat">
            <span style="font-size:3rem;">📖</span>
            <p style="font-family:'Playfair Display',serif;font-size:1.1rem;color:#7a4a28;">
              No messages yet
            </p>
            <p>Be the first to start the conversation!</p>
          </div>
        <% } else {
          let lastDate = null;
          community.messages.forEach(msg => {
            const msgDate    = new Date(msg.createdAt);
            const dateStr    = msgDate.toLocaleDateString('en-US', { weekday:'long', month:'short', day:'numeric' });
            const isMine     = msg.author && msg.author._id.toString() === userId;
            const initials   = msg.author && msg.author.name ? msg.author.name.charAt(0).toUpperCase() : '?';
            const authorName = msg.author ? msg.author.name : 'Unknown';
            const timeStr    = msgDate.toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });

            // Unique color per user ID so two users with same name look different
            const authorId  = msg.author ? msg.author._id.toString() : '000';
            const colorSeed = parseInt(authorId.slice(-4), 16) % avatarColors.length;
        %>
          <% if (dateStr !== lastDate) { lastDate = dateStr; %>
            <div class="date-divider"><%= dateStr %></div>
          <% } %>

          <div class="msg-row <%= isMine ? 'mine' : 'other' %>">
            <div class="msg-avatar" style="background:<%= avatarColors[colorSeed] %>">
              <%= initials %>
            </div>
            <div class="msg-content">
              <% if (!isMine) { %>
                <div class="msg-author-name" style="color:<%= avatarColors[colorSeed] %>">
                  <%= authorName %> <span style="font-size:9px;opacity:0.5;font-weight:400;">·&nbsp;<%= authorId.slice(-4) %></span>
                </div>
              <% } %>
              <div class="msg-bubble"><%- msg.content.replace(/\n/g, '<br/>') %></div>
              <div class="msg-time"><%= timeStr %></div>
            </div>
          </div>

        <% }) %>
        <% } %>
      </div>

      <!-- Input bar -->
      <div class="input-bar">
        <form action="/communities/<%= community._id %>/chat" method="POST" id="chat-form">
          <textarea
            name="content"
            id="msg-input"
            class="msg-input"
            placeholder="Type a message… (Enter to send, Shift+Enter for new line)"
            rows="1"
            maxlength="1000"
            oninput="autoResize(this)"
            onkeydown="handleKey(event)"></textarea>
          <button type="submit" class="send-btn" title="Send">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
            </svg>
          </button>
        </form>
      </div>

    </div>
  </div>

  <script>
    // ── Scroll to bottom on load ──────────────────────────────────────────
    const area = document.getElementById('messages-area');
    if (area) area.scrollTop = area.scrollHeight;

    // ── Auto-dismiss flash messages ───────────────────────────────────────
    ['flash-success', 'flash-error'].forEach(id => {
      const el = document.getElementById(id);
      if (el) setTimeout(() => el.style.display = 'none', 3500);
    });

    // ── Members dropdown toggle ───────────────────────────────────────────
    function toggleMembers(e) {
      e.stopPropagation();
      document.getElementById('members-dropdown').classList.toggle('open');
    }
    document.addEventListener('click', () => {
      document.getElementById('members-dropdown')?.classList.remove('open');
    });

    // ── Textarea: Enter = submit, Shift+Enter = newline ───────────────────
    function handleKey(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        const val = document.getElementById('msg-input').value.trim();
        if (val) document.getElementById('chat-form').submit();
      }
    }

    function autoResize(el) {
      el.style.height = 'auto';
      el.style.height = Math.min(el.scrollHeight, 100) + 'px';
    }

    // ── Auto-refresh every 5 seconds ──────────────────────────────────────
    // Only reload if user is not typing
    let isTyping = false;
    document.getElementById('msg-input').addEventListener('focus', () => isTyping = true);
    document.getElementById('msg-input').addEventListener('blur',  () => isTyping = false);

    setInterval(() => {
      if (!isTyping) location.reload();
    }, 5000);
  </script>

</body>
</html>