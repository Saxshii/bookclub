<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
</head>
<body style="background:#faf7f2; min-height:100vh; font-family:'Lato',sans-serif;">

  <%- include('../partials/navbar') %>

  <div style="max-width:1100px; margin:0 auto; padding:100px 24px 60px;">

    <!-- Header -->
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:32px;">
      <div>
        <h1 style="font-family:'Playfair Display',serif; font-size:2rem;
                   font-weight:700; color:#3d1f08;">Admin Dashboard</h1>
        <p style="color:#a8845a; font-size:13px; margin-top:4px;">
          Welcome back — here's what's happening on BookClub
        </p>
      </div>
      <span style="background:#3d1f08; color:#f0e6d3; font-size:11px;
                   padding:6px 16px; border-radius:9999px; letter-spacing:.1em;">
        ADMIN
      </span>
    </div>

    <!-- Stat cards -->
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:32px;">

      <div style="background:white; border:1px solid #e8d5b7; border-radius:14px; padding:20px;">
        <p style="font-size:11px; text-transform:uppercase; letter-spacing:.08em;
                  color:#a8845a; margin-bottom:8px;">Total Users</p>
        <p style="font-family:'Playfair Display',serif; font-size:2.2rem;
                  font-weight:700; color:#3d1f08;"><%= totalUsers %></p>
        <p style="font-size:11px; color:#22c55e; margin-top:4px;">
          +<%= newUsersThisWeek %> this week
        </p>
      </div>

      <div style="background:white; border:1px solid #e8d5b7; border-radius:14px; padding:20px;">
        <p style="font-size:11px; text-transform:uppercase; letter-spacing:.08em;
                  color:#a8845a; margin-bottom:8px;">Communities</p>
        <p style="font-family:'Playfair Display',serif; font-size:2.2rem;
                  font-weight:700; color:#3d1f08;"><%= totalCommunities %></p>
        <p style="font-size:11px; color:#a8845a; margin-top:4px;">across all genres</p>
      </div>

      <div style="background:white; border:1px solid #e8d5b7; border-radius:14px; padding:20px;">
        <p style="font-size:11px; text-transform:uppercase; letter-spacing:.08em;
                  color:#a8845a; margin-bottom:8px;">New This Week</p>
        <p style="font-family:'Playfair Display',serif; font-size:2.2rem;
                  font-weight:700; color:#3d1f08;"><%= newUsersThisWeek %></p>
        <p style="font-size:11px; color:#22c55e; margin-top:4px;">new signups</p>
      </div>

      <div style="background:white; border:1px solid #e8d5b7; border-radius:14px; padding:20px;">
        <p style="font-size:11px; text-transform:uppercase; letter-spacing:.08em;
                  color:#a8845a; margin-bottom:8px;">Flagged</p>
        <p style="font-family:'Playfair Display',serif; font-size:2.2rem;
                  font-weight:700; color:#3d1f08;">
          <%= communities.filter(c => c.isFlagged).length %>
        </p>
        <p style="font-size:11px; color:#ef4444; margin-top:4px;">needs review</p>
      </div>
    </div>

    <!-- Two columns -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px;">

      <!-- Communities table -->
      <div style="background:white; border:1px solid #e8d5b7; border-radius:14px; padding:24px;">
        <h2 style="font-size:11px; text-transform:uppercase; letter-spacing:.08em;
                   color:#a8845a; font-weight:600; margin-bottom:20px;">
          Communities
        </h2>
        <table style="width:100%; font-size:13px; border-collapse:collapse;">
          <thead>
            <tr style="border-bottom:1px solid #e8d5b7;">
              <th style="text-align:left; padding-bottom:10px; color:#a8845a;
                         font-size:11px; font-weight:500; text-transform:uppercase;">Name</th>
              <th style="text-align:left; padding-bottom:10px; color:#a8845a;
                         font-size:11px; font-weight:500; text-transform:uppercase;">Genre</th>
              <th style="text-align:left; padding-bottom:10px; color:#a8845a;
                         font-size:11px; font-weight:500; text-transform:uppercase;">Members</th>
              <th style="text-align:left; padding-bottom:10px; color:#a8845a;
                         font-size:11px; font-weight:500; text-transform:uppercase;">Status</th>
            </tr>
          </thead>
          <tbody>
            <% communities.forEach(c => { %>
              <tr style="border-bottom:1px solid #f5efe6;">
                <td style="padding:10px 0; color:#3d1f08; font-weight:500;">
                  <%= c.name %>
                </td>
                <td style="padding:10px 0;">
                  <span style="background:#f0e6d3; color:#7a4a28; font-size:10px;
                               padding:4px 10px; border-radius:9999px;">
                    <%= c.genre %>
                  </span>
                </td>
                <td style="padding:10px 0; color:#3d1f08;">
                  <%= c.members ? c.members.length : 0 %>
                </td>
                <td style="padding:10px 0;">
                  <% if (c.isFlagged) { %>
                    <span style="background:#fef2f2; color:#ef4444; font-size:10px;
                                 padding:4px 10px; border-radius:9999px;">Flagged</span>
                  <% } else { %>
                    <span style="background:#f0fdf4; color:#16a34a; font-size:10px;
                                 padding:4px 10px; border-radius:9999px;">Active</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Recent users -->
      <div style="background:white; border:1px solid #e8d5b7; border-radius:14px; padding:24px;">
        <h2 style="font-size:11px; text-transform:uppercase; letter-spacing:.08em;
                   color:#a8845a; font-weight:600; margin-bottom:20px;">
          Recent Users
        </h2>
        <% recentUsers.forEach(u => { %>
          <div style="display:flex; align-items:center; gap:12px;
                      padding:10px 0; border-bottom:1px solid #f5efe6;">
            <img src="<%= u.getAvatar ? u.getAvatar() : `https://ui-avatars.com/api/?name=${encodeURIComponent(u.name)}&background=c9a96e&color=fff&bold=true&size=64` %>"
                 alt="<%= u.name %>"
                 style="width:36px; height:36px; border-radius:50%;
                        object-fit:cover; flex-shrink:0;"/>
            <div style="flex:1; min-width:0;">
              <p style="font-size:13px; font-weight:600; color:#3d1f08;
                        white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                <%= u.name %>
              </p>
              <p style="font-size:11px; color:#a8845a; white-space:nowrap;
                        overflow:hidden; text-overflow:ellipsis;">
                <%= u.email %>
              </p>
            </div>
            <p style="font-size:11px; color:#a8845a; flex-shrink:0;">
              <%= new Date(u.createdAt).toLocaleDateString('en-IN', {
                day: 'numeric', month: 'short'
              }) %>
            </p>
          </div>
        <% }) %>
      </div>
    </div>

  </div>

  <%- include('../partials/footer') %>
</body>
</html>