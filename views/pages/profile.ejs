<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
</head>
<body class="bg-cream min-h-screen">

  <%- include('../partials/navbar') %>

  <div class="pt-24 pb-16 px-4">
    <div class="max-w-4xl mx-auto">

      <!-- Flash messages -->
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flash-success mb-6"><span>✓</span> <%= success_msg %></div>
      <% } %>

      <!-- Profile card -->
      <div class="bg-white rounded-3xl shadow-warm-lg overflow-hidden mb-8">

        <!-- Header banner -->
        <div class="h-32 bg-gradient-to-r from-amber-800 via-amber-700 to-amber-600"></div>

        <!-- Avatar + name -->
        <div class="px-8 pb-8">
          <div class="flex flex-col sm:flex-row sm:items-end gap-4 -mt-12 mb-6">
            <img src="<%= user.getAvatar() %>"
                 alt="<%= user.name %>"
                 class="w-24 h-24 rounded-2xl border-4 border-white shadow-lg object-cover"/>
            <div class="pb-1">
              <h1 class="font-serif text-3xl font-bold text-amber-900"><%= user.name %></h1>
              <p class="text-amber-600 text-sm"><%= user.email %></p>
              <p class="text-amber-500 text-xs mt-0.5">
                Member since <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %>
              </p>
            </div>
          </div>

          <!-- Bio -->
          <% if (user.bio) { %>
            <p class="text-amber-700 text-sm leading-relaxed mb-4 max-w-lg"><%= user.bio %></p>
          <% } %>

          <!-- Favourite genres badges -->
          <% if (user.favoriteGenres && user.favoriteGenres.length > 0) { %>
            <div class="flex flex-wrap gap-2">
              <% user.favoriteGenres.forEach(g => { %>
                <span class="bg-amber-100 text-amber-800 text-xs font-medium
                             px-3 py-1 rounded-full border border-amber-200">
                  <%= g %>
                </span>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <% const statCards = [
          { label: 'Total Books', value: stats.total, emoji: '📚', color: 'amber' },
          { label: 'Finished',    value: stats.finished, emoji: '✅', color: 'green' },
          { label: 'Reading Now', value: stats.reading, emoji: '📖', color: 'blue' },
          { label: 'Want to Read',value: stats.wantToRead, emoji: '🔖', color: 'purple' }
        ] %>
        <% statCards.forEach(s => { %>
          <div class="bg-white rounded-2xl p-5 shadow-warm text-center border border-amber-50">
            <p class="text-3xl mb-1"><%= s.emoji %></p>
            <p class="font-serif text-3xl font-bold text-amber-900"><%= s.value %></p>
            <p class="text-amber-600 text-xs mt-1"><%= s.label %></p>
          </div>
        <% }) %>
      </div>

      <!-- Recent books -->
      <% if (recentBooks.length > 0) { %>
        <div class="bg-white rounded-2xl shadow-warm p-6 mb-8 border border-amber-50">
          <div class="flex items-center justify-between mb-4">
            <h2 class="font-serif text-xl font-semibold text-amber-900">Recently Added</h2>
            <a href="/books/bookshelf" class="text-amber-600 hover:text-amber-800 text-sm transition-colors">
              View all →
            </a>
          </div>
          <div class="flex gap-4 flex-wrap">
            <% recentBooks.forEach(book => { %>
              <div class="flex items-center gap-3 bg-amber-50 rounded-xl p-3 flex-1 min-w-[200px]">
                <img
                  src="<%= book.coverId ? `https://covers.openlibrary.org/b/id/${book.coverId}-S.jpg` : '/images/fallback-cover.jpg' %>"
                  alt="<%= book.title %>"
                  class="w-10 h-14 object-cover rounded shadow-sm flex-shrink-0"
                  onerror="this.src='/images/fallback-cover.jpg'"
                />
                <div class="min-w-0">
                  <p class="font-semibold text-amber-900 text-xs truncate"><%= book.title %></p>
                  <p class="text-amber-600 text-xs truncate"><%= book.author %></p>
                  <span class="text-xs px-2 py-0.5 rounded-full mt-1 inline-block
                    <%= book.readingStatus === 'finished' ? 'bg-green-100 text-green-700' :
                        book.readingStatus === 'currently-reading' ? 'bg-amber-100 text-amber-700' :
                        'bg-gray-100 text-gray-600' %>">
                    <%= book.readingStatus.replace('-', ' ') %>
                  </span>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Edit profile form -->
      <div class="bg-white rounded-2xl shadow-warm p-6 border border-amber-50">
        <h2 class="font-serif text-xl font-semibold text-amber-900 mb-5">Edit Profile</h2>

        <form action="/profile/update" method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-amber-800 mb-1.5">Display Name</label>
            <input type="text" name="name" value="<%= user.name %>" class="form-input"/>
          </div>
          <div>
            <label class="block text-sm font-medium text-amber-800 mb-1.5">Bio</label>
            <textarea name="bio" rows="3"
                      placeholder="Tell the BookClub community about yourself..."
                      class="form-input resize-none"><%= user.bio || '' %></textarea>
          </div>

          <!-- Favourite genres checkboxes -->
          <div>
            <label class="block text-sm font-medium text-amber-800 mb-2">Favourite Genres</label>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
              <% ['Fantasy','Romance','Thriller','Mystery','Sci-Fi','Horror','Historical','Non-Fiction'].forEach(g => { %>
                <label class="flex items-center gap-2 cursor-pointer group">
                  <input type="checkbox" name="favoriteGenres" value="<%= g %>"
                         <%= user.favoriteGenres && user.favoriteGenres.includes(g) ? 'checked' : '' %>
                         class="w-4 h-4 rounded border-amber-300 text-amber-600
                                focus:ring-amber-400 cursor-pointer"/>
                  <span class="text-sm text-amber-800 group-hover:text-amber-600 transition-colors">
                    <%= g %>
                  </span>
                </label>
              <% }) %>
            </div>
          </div>

          <button type="submit" class="btn-primary">Save Profile</button>
        </form>
      </div>

    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>