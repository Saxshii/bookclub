<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
</head>
<body class="bg-cream min-h-screen">

  <%- include('../partials/navbar') %>

  <!-- Page header -->
  <div class="pt-28 pb-12 px-4 text-center bg-gradient-to-b from-amber-50 to-cream">
    <h1 class="font-serif text-5xl font-bold text-amber-900 mb-3">Explore Genres</h1>
    <p class="text-amber-600 max-w-xl mx-auto">
      Every genre is a different world. Which one will you enter today?
    </p>
  </div>

  <!-- Genres grid -->
  <section class="max-w-7xl mx-auto px-4 pb-24">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% genres.forEach(genre => { %>
        <a href="/genre/<%= genre.slug %>"
           class="genre-card block group" style="height: 260px;">

          <!-- BG image -->
          <div class="absolute inset-0">
            <img src="<%= genre.cardImage %>"
                 alt="<%= genre.name %>"
                 class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                 onerror="this.style.display='none'"/>
          </div>

          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-black/10"></div>

          <!-- Content -->
          <div class="absolute inset-0 flex flex-col justify-end p-6">
            <span class="inline-flex items-center gap-1 text-amber-400 text-sm font-medium
                         group-hover:gap-2 transition-all duration-200">
              Browse books <span>→</span>
            </span>
          </div>

          <!-- Hover border glow -->
          <div class="absolute inset-0 rounded-2xl ring-2 ring-transparent
                      group-hover:ring-amber-400/60 transition-all duration-300"></div>
        </a>
      <% }) %>
    </div>
  </section>

  <%- include('../partials/footer') %>
</body>
</html>