<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/css/output.css" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap"
    rel="stylesheet" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background-image: url('/images/shelf.jpg');
      background-size: cover;
      background-attachment: fixed;
      background-position: center;
      font-family: 'Lato', sans-serif;
      overflow-x: hidden;
    }

    .page-overlay {
      min-height: 100vh;
      background: rgba(8, 4, 1, 0.42);
    }

    /* ── Header ── */
    .shelf-header {
      text-align: center;
      padding: 88px 24px 28px;
    }

    .shelf-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      color: #f5e6d0;
      text-shadow: 0 2px 20px rgba(0, 0, 0, 0.7);
      margin-bottom: 5px;
    }

    #book-count-display {
      color: rgba(245, 220, 180, 0.45);
      font-size: 13px;
      letter-spacing: .06em;
    }

    /* ── Search ── */
    .search-area {
      max-width: 380px;
      margin: 0 0 36px auto;
      padding: 0 80px 0 20px;
      position: relative;
      z-index: 50;
      margin-top: -10px;
    }

    .search-input-wrap {
      position: relative;
    }

    .search-area input {
      width: 100%;
      padding: 11px 42px 11px 18px;
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(245, 220, 180, 0.22);
      border-radius: 9999px;
      color: #f5e6d0;
      font-size: 14px;
      outline: none;
      transition: all .3s;
      font-family: 'Lato', sans-serif;
    }

    .search-area input::placeholder {
      color: rgba(245, 220, 180, 0.38);
    }

    .search-area input:focus {
      background: rgba(255, 255, 255, 0.15);
      border-color: rgba(201, 169, 110, 0.5);
    }

    .s-icon {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(201, 169, 110, 0.55);
      font-size: 14px;
      pointer-events: none;
    }

    #search-dropdown {
      display: none;
      background: rgba(12, 6, 2, 0.97);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(201, 169, 110, 0.18);
      border-radius: 0 0 14px 14px;
      max-height: 270px;
      overflow-y: auto;
    }

    .search-result-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 13px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      transition: background .15s;
    }

    .search-result-row:hover {
      background: rgba(201, 169, 110, 0.07);
    }

    .search-result-row img {
      width: 30px;
      height: 44px;
      object-fit: cover;
      border-radius: 3px;
      flex-shrink: 0;
      background: #2c1810;
    }

    .search-result-info {
      flex: 1;
      min-width: 0;
    }

    .search-result-info p:first-child {
      color: rgba(245, 220, 180, 0.88);
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .search-result-info p:last-child {
      color: rgba(245, 220, 180, 0.38);
      font-size: 11px;
      margin-top: 1px;
    }

    .add-search-btn {
      flex-shrink: 0;
      background: #c9a96e;
      color: #1a0a00;
      border: none;
      padding: 5px 11px;
      border-radius: 9999px;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: background .2s;
      font-family: 'Lato', sans-serif;
    }

    .add-search-btn:hover {
      background: #e8c87a;
    }

    .add-search-btn.added {
      background: #4ade80;
      color: #052e16;
    }

    .add-search-btn:disabled {
      opacity: .6;
      cursor: default;
    }

    .done-btn-wrap {
      display: none;
      justify-content: center;
      margin-top: 9px;
    }

    .done-btn {
      background: rgba(201, 169, 110, 0.12);
      border: 1px solid rgba(201, 169, 110, 0.38);
      color: #c9a96e;
      padding: 6px 22px;
      border-radius: 9999px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Lato', sans-serif;
      transition: all .2s;
    }

    .done-btn:hover {
      background: rgba(201, 169, 110, 0.22);
    }

    /* ══════════════════════════════════════════
       3D CAROUSEL
    ══════════════════════════════════════════ */
    .carousel-scene {
      width: 100%;
      perspective: 2200px;
      perspective-origin: 50% 40%;
      padding: 10px 0 50px;
      position: relative;
    }

    .carousel-track {
      display: flex;
      justify-content: center;
      align-items: center;
      /* No gap — depth illusion handles spacing */
      gap: 0;
      position: relative;
      height: 600px;
      /* fixed height so almirahs overlap correctly */
    }

    /* ── Almirah ── */
    .almirah {
      position: absolute;
      width: 660px;
      height: 600px;
      border-radius: 8px;
      overflow: hidden;
      cursor: pointer;
      /* All transitions on transform, opacity, filter */
      transition:
        transform .6s cubic-bezier(.25, .46, .45, .94),
        opacity .6s ease,
        filter .6s ease,
        z-index 0s .3s;
      will-change: transform, opacity, filter;
    }

    /* CENTER — full focus */
    .almirah.state-center {
      transform: perspective(1600px) rotateY(0deg) translateZ(0px) scale(1);
      opacity: 1;
      filter: brightness(1) blur(0);
      z-index: 20;
      cursor: default;
      box-shadow: 0 30px 80px rgba(0, 0, 0, 0.7);
    }

    /* LEFT — tilted back, slightly left */
    .almirah.state-left {
      transform: perspective(1600px) rotateY(38deg) translateX(-460px) translateZ(-140px) scale(0.82);
      opacity: 0.72;
      filter: brightness(0.68) blur(0.4px);
      z-index: 10;
    }

    /* RIGHT — tilted back, slightly right */
    .almirah.state-right {
      transform: perspective(1600px) rotateY(-38deg) translateX(460px) translateZ(-140px) scale(0.82);
      opacity: 0.72;
      filter: brightness(0.68) blur(0.4px);
      z-index: 10;
    }

    /* FAR LEFT/RIGHT — mostly hidden */
    .almirah.state-far-left {
      transform: perspective(1600px) rotateY(55deg) translateX(-700px) translateZ(-300px) scale(0.65);
      opacity: 0.2;
      filter: brightness(0.4) blur(1px);
      z-index: 5;
    }

    .almirah.state-far-right {
      transform: perspective(1600px) rotateY(-55deg) translateX(700px) translateZ(-300px) scale(0.65);
      opacity: 0.2;
      filter: brightness(0.4) blur(1px);
      z-index: 5;
    }

    .almirah:not(.state-center):hover {
      filter: brightness(0.8) blur(0px);
      opacity: 0.88;
    }

    /* ── Almirah inner — shelf-bg.jpg fills exactly ── */
    .almirah-inner {
      width: 100%;
      height: 100%;
      background-image: url('/images/shelf-bg.jpg');
      background-size: 100% 100%;
      /* stretch to fill perfectly */
      background-repeat: no-repeat;
      position: relative;
    }

    .shelf-rows-wrap {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .shelf-row {
      position: absolute;
      left: 3%;
      right: 3%;
      display: flex;
      align-items: flex-end;
      gap: 0;
      justify-content: space-evenly;
      overflow: hidden;
      pointer-events: all;
      padding: 0 10px;
    }

    /* Row positions — tune to your shelf-bg.jpg */
    .shelf-row:nth-child(1) {
      top: 1%;
      height: 26%;
    }

    .shelf-row:nth-child(2) {
      top: 25%;
      height: 26%;
    }

    .shelf-row:nth-child(3) {
      top: 49%;
      height: 26%;
    }

    .shelf-row:nth-child(4) {
      top: 73%;
      height: 25%;
    }

    /* ── Book (cover only) ── */
    .book-item {
      flex-shrink: 0;
      flex-grow: 0;
      width: 65px;
      height: 70%;
      max-height: 100%;
      position: relative;
      cursor: pointer;
      transition: transform .22s ease;
      align-self: flex-end;
    }

    .book-item:hover {
      transform: translateY(-10px) scale(1.06);
      z-index: 30;
    }

    .book-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 2px 5px 5px 2px;
      box-shadow:
        2px 2px 8px rgba(0, 0, 0, 0.55),
        inset -2px 0 3px rgba(0, 0, 0, 0.12);
      display: block;
    }

    /* Spine shadow */
    .book-item::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 5px;
      background: linear-gradient(90deg, rgba(0, 0, 0, 0.42), transparent);
      border-radius: 2px 0 0 2px;
      z-index: 2;
      pointer-events: none;
    }

    /* Status dot */
    .status-dot {
      position: absolute;
      top: 3px;
      right: 3px;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      border: 1.5px solid rgba(255, 255, 255, 0.65);
      z-index: 5;
    }

    .dot-reading {
      background: #f59e0b;
    }

    .dot-finished {
      background: #22c55e;
    }

    .dot-want {
      background: rgba(200, 200, 200, 0.3);
    }

    /* Fallback cover */
    .book-fallback {
      width: 100%;
      height: 100%;
      background: linear-gradient(160deg, #3d1f0a, #6b3a1f);
      border-radius: 2px 5px 5px 2px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4px;
      text-align: center;
      box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.55);
    }

    .book-fallback span {
      font-size: 14px;
    }

    .book-fallback p {
      font-size: 7px;
      color: rgba(245, 220, 180, 0.7);
      margin-top: 3px;
      line-height: 1.2;
      font-family: 'Playfair Display', serif;
      overflow: hidden;
      max-height: 40px;
    }

    /* ── Nav arrows ── */
    .nav-arrow {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(15, 7, 3, 0.55);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(201, 169, 110, 0.22);
      color: rgba(245, 220, 180, 0.65);
      width: 46px;
      height: 46px;
      border-radius: 50%;
      font-size: 20px;
      cursor: pointer;
      z-index: 100;
      transition: all .2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nav-arrow:hover {
      background: rgba(201, 169, 110, 0.18);
      border-color: rgba(201, 169, 110, 0.45);
      color: #f5e6d0;
    }

    #nav-prev {
      left: 14px;
    }

    #nav-next {
      right: 14px;
    }

    /* ── Dots ── */
    .carousel-dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      padding: 16px 0 44px;
    }

    .carousel-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(245, 220, 180, 0.18);
      border: 1px solid rgba(245, 220, 180, 0.28);
      cursor: pointer;
      transition: all .3s;
    }

    .carousel-dot.active {
      background: #c9a96e;
      border-color: #c9a96e;
      transform: scale(1.3);
    }

    /* ── Modal ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(8, 4, 1, 0.82);
      backdrop-filter: blur(6px);
      z-index: 200;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .modal-overlay.open {
      display: flex;
    }

    .modal-box {
      background: #fffdf8;
      border-radius: 20px;
      width: 100%;
      max-width: 540px;
      max-height: 88vh;
      overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }

    /* ── Toast ── */
    #shelf-toast {
      position: fixed;
      bottom: 22px;
      right: 22px;
      background: rgba(12, 6, 2, 0.95);
      border: 1px solid rgba(201, 169, 110, 0.28);
      color: #f0e6d3;
      padding: 10px 17px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 500;
      z-index: 300;
      opacity: 0;
      transform: translateY(12px);
      transition: all .3s ease;
      pointer-events: none;
    }

    #shelf-toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    /* Mobile */
    @media(max-width:720px) {
      .carousel-track {
        height: 480px;
      }

      .almirah {
        width: calc(100vw - 40px);
        height: 420px;
      }

      .almirah.state-left {
        transform: perspective(800px) rotateY(28deg) translateX(-50vw) translateZ(-80px) scale(0.8);
      }

      .almirah.state-right {
        transform: perspective(800px) rotateY(-28deg) translateX(50vw) translateZ(-80px) scale(0.8);
      }
    }
  </style>
</head>

<body>

  <%- include('../partials/navbar') %>

    <div class="page-overlay">

      <!-- Header -->
      <div class="shelf-header">
        <h1>My Bookshelf</h1>
        <p id="book-count-display">
          <%= totalBooks %> book<%= totalBooks !==1 ? 's' : '' %> in your collection
        </p>
      </div>

      <!-- Search -->
      <div class="search-area">
        <div class="search-input-wrap">
          <input type="text" id="book-search" placeholder="Search any book or author..." autocomplete="off" />
          <span class="s-icon">🔍</span>
        </div>
        <div id="search-dropdown"></div>
        <div class="done-btn-wrap" id="done-btn-wrap">
          <button class="done-btn" onclick="doneAdding()">✓ Done — update shelf</button>
        </div>
      </div>

      <!-- Nav arrows -->
      <button class="nav-arrow" id="nav-prev" onclick="navigate(-1)">‹</button>
      <button class="nav-arrow" id="nav-next" onclick="navigate(1)">›</button>

      <!-- Carousel -->
      <div class="carousel-scene">
        <div class="carousel-track" id="carousel-track">

          <% const SHELVES=4; const PER_SHELF=8; const PER_ALMIRAH=SHELVES * PER_SHELF; const allBooks=bookshelf.books
            || []; const almirahs=[]; const totalAlmirahs=Math.max(2, Math.ceil(allBooks.length / PER_ALMIRAH)); for
            (let i=0; i < totalAlmirahs; i++) { almirahs.push(allBooks.slice(i * PER_ALMIRAH, (i + 1) * PER_ALMIRAH)); }
            %>

            <% almirahs.forEach((almBooks, aIdx)=> { %>
              <% let stateClass='state-far-right' ; if (aIdx===0) stateClass='state-center' ; else if (aIdx===1)
                stateClass='state-right' ; else if (aIdx===almirahs.length - 1 && almirahs.length> 2)
                stateClass = 'state-far-right';
                %>
                <div class="almirah <%= stateClass %>" data-idx="<%= aIdx %>" onclick="almirahClick(<%= aIdx %>)">
                  <div class="almirah-inner">
                    <div class="shelf-rows-wrap">

                      <% const rows=[]; for (let r=0; r < SHELVES; r++) { rows.push(almBooks.slice(r * PER_SHELF, (r+1)
                        * PER_SHELF)); } %>

                        <% rows.forEach((rowBooks, rIdx)=> { %>
                          <div class="shelf-row">
                            <% rowBooks.forEach(book=> {
                              const src = book.coverId
                              ? `https://covers.openlibrary.org/b/id/${book.coverId}-M.jpg`
                              : (book.coverUrl || '');
                              const dotCls = book.readingStatus === 'finished' ? 'dot-finished'
                              : book.readingStatus === 'currently-reading' ? 'dot-reading'
                              : 'dot-want';
                              const st = book.title.replace(/'/g,"&apos;").replace(/"/g,"&quot;");
                              const sa = (book.author||'Unknown').replace(/'/g,"&apos;");
                              const scu = (book.coverUrl||'').replace(/'/g,"&apos;");
                              const sn = (book.notes||'').replace(/'/g,"&apos;").replace(/\n/g,"\\n");
                              const sr = (book.review||'').replace(/'/g,"&apos;");
                              %>
                              <div class="book-item"
                                onclick="openModal('<%= book._id %>','<%= st %>','<%= sa %>','<%= book.coverId||"" %>','<%= scu %>','<%= book.readingStatus %>','<%= sn %>','<%= sr %>','<%= book.rating||"" %>')">
                                <div class="status-dot <%= dotCls %>"></div>
                                <% if (src) { %>
                                  <img src="<%= src %>" alt="<%= book.title %>"
                                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                  <div class="book-fallback" style="display:none;">
                                    <span>📚</span>
                                    <p>
                                      <%= book.title.substring(0,18) %>
                                    </p>
                                  </div>
                                  <% } else { %>
                                    <div class="book-fallback">
                                      <span>📚</span>
                                      <p>
                                        <%= book.title.substring(0,18) %>
                                      </p>
                                    </div>
                                    <% } %>
                              </div>
                              <% }) %>
                          </div>
                          <% }) %>

                    </div>
                  </div>
                </div>
                <% }) %>

        </div>
      </div>

      <!-- Dots -->
      <div class="carousel-dots">
        <% almirahs.forEach((_, i)=> { %>
          <div class="carousel-dot <%= i === 0 ? 'active' : '' %>" onclick="goTo(<%= i %>)"></div>
          <% }) %>
      </div>

      <%- include('../partials/footer') %>
    </div>

    <!-- Modal -->
    <div class="modal-overlay" id="modal-overlay">
      <div class="modal-box">
        <div id="modal-content"></div>
      </div>
    </div>

    <div id="shelf-toast"></div>

    <script src="/js/bookshelf.js"></script>
</body>

</html>