<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/css/output.css" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background-image: url('<%= genre.bgImage %>');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      font-family: 'Lato', sans-serif;
    }

    .overlay {
      min-height: 100vh;
      background: linear-gradient(to bottom,
          rgba(0, 0, 0, 0.6) 0%,
          rgba(0, 0, 0, 0.4) 15%,
          rgba(0, 0, 0, 0.6) 60%,
          rgba(0, 0, 0, 0.92) 100%);
    }

    /* ── Back button ── */
    .back-btn {
      position: fixed;
      top: 22px;
      left: 22px;
      z-index: 200;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.18);
      color: rgba(255, 255, 255, 0.9);
      font-size: 20px;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }

    .back-btn:hover {
      background: rgba(0, 0, 0, 0.65);
      border-color: rgba(255, 255, 255, 0.4);
    }

    /* ── FIX 1: Top bar — arrow left, search right, same line ── */
    .top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 48px 0 120px;
    }

    /* ── Search ── */
    .search-wrap {
      position: relative;
      width: 300px;
      flex-shrink: 0;
    }

    .search-input {
      width: 100%;
      padding: 11px 42px 11px 18px;
      background: rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(14px);
      border: 1px solid rgba(255, 255, 255, 0.22);
      border-radius: 9999px;
      color: #fff;
      font-size: 13px;
      font-family: 'Lato', sans-serif;
      outline: none;
      transition: all 0.25s;
    }

    .search-input::placeholder {
      color: rgba(255, 255, 255, 0.45);
    }

    .search-input:focus {
      background: rgba(255, 255, 255, 0.18);
      border-color: rgba(255, 255, 255, 0.4);
    }

    .search-icon {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(255, 255, 255, 0.45);
      pointer-events: none;
    }

    .search-icon svg {
      width: 15px;
      height: 15px;
      display: block;
    }

    #search-dropdown {
      display: none;
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      width: 360px;
      background: rgba(12, 6, 2, 0.97);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(201, 169, 110, 0.25);
      border-radius: 16px;
      z-index: 100;
      max-height: 340px;
      overflow-y: auto;
    }

    .drop-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      cursor: default;
      transition: background 0.15s;
    }

    .drop-item:last-child {
      border-bottom: none;
    }

    .drop-item:hover {
      background: rgba(201, 169, 110, 0.1);
    }

    .drop-cover {
      width: 34px;
      height: 50px;
      object-fit: cover;
      border-radius: 4px;
      flex-shrink: 0;
      background: #2c1810;
    }

    .drop-title {
      color: rgba(255, 255, 255, 0.9);
      font-size: 13px;
      font-weight: 600;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .drop-author {
      color: rgba(255, 255, 255, 0.4);
      font-size: 11px;
      margin-top: 2px;
    }

    .drop-btn {
      flex-shrink: 0;
      background: #c9a96e;
      color: #1a0a00;
      border: none;
      padding: 5px 13px;
      border-radius: 9999px;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s;
    }

    .drop-btn:hover {
      background: #e8c87a;
    }

    /* ── Books grid ── */
    .books-section {
      max-width: 1380px;
      margin: 0 auto;
      padding: 36px 48px 60px;
    }

    .books-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 32px 24px;
    }

    /* ── Book card ── */
    .book-card {
      transition: transform 0.3s ease;
      cursor: pointer;
    }

    .book-card:hover {
      transform: translateY(-10px);
    }

    .cover-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 2 / 3;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
    }

    .book-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.45s ease;
    }

    .book-card:hover .book-img {
      transform: scale(1.04);
    }

    /* Hover overlay — add to shelf */
    .shelf-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.7);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
      border-radius: 10px;
    }

    .book-card:hover .shelf-overlay {
      opacity: 1;
    }

    .add-btn {
      background: #c9a96e;
      color: #1a0a00;
      border: none;
      padding: 9px 18px;
      border-radius: 9999px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Lato', sans-serif;
      transition: background 0.2s;
      white-space: nowrap;
    }

    .add-btn:hover {
      background: #e8c87a;
    }

    .add-btn.saved {
      background: #4ade80;
      color: #052e16;
    }

    .add-btn:disabled {
      opacity: 0.65;
      cursor: default;
    }

    .book-info {
      margin-top: 10px;
      padding: 0 2px;
    }

    .book-title {
      font-family: 'Playfair Display', serif;
      font-size: 13px;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.92);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 3px;
    }

    .book-author {
      font-size: 11px;
      color: rgba(255, 255, 255, 0.45);
    }

    /* ── Pagination ── */
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      padding: 24px 24px 40px;
      flex-wrap: wrap;
    }

    .page-btn {
      padding: 8px 18px;
      border-radius: 9999px;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      font-family: 'Lato', sans-serif;
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: rgba(255, 255, 255, 0.75);
      transition: all 0.2s;
    }

    .page-btn:hover {
      background: rgba(255, 255, 255, 0.22);
      color: #fff;
    }

    .page-btn.active {
      background: #c9a96e;
      color: #1a0a00;
      border-color: #c9a96e;
    }

    .page-btn.disabled {
      opacity: 0.3;
      pointer-events: none;
    }

    /* ── Toast ── */
    #toast {
      position: fixed;
      bottom: 28px;
      right: 28px;
      background: rgba(20, 10, 3, 0.95);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(201, 169, 110, 0.3);
      color: #f0e6d3;
      padding: 12px 22px;
      border-radius: 12px;
      font-size: 13px;
      font-weight: 500;
      z-index: 999;
      opacity: 0;
      transform: translateY(16px);
      transition: all 0.3s ease;
      pointer-events: none;
    }

    #toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    footer {
      background: rgba(8, 4, 1, 0.88) !important;
      backdrop-filter: blur(12px);
      border-top: 1px solid rgba(201, 169, 110, 0.12);
    }

    @media (max-width: 768px) {
      .top-bar {
        padding: 22px 20px 0;
      }

      .search-wrap {
        width: 100%;
      }

      #search-dropdown {
        width: 100%;
        right: auto;
        left: 0;
      }

      .books-section {
        padding: 28px 20px 48px;
      }

      .books-grid {
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 20px 16px;
      }
    }
  </style>
</head>

<body>

  <a href="/explore" class="back-btn" title="Back">&#8592;</a>

  <div class="overlay">

    <!-- FIX 1: search aligned right on same line as back button -->
    <div class="top-bar">
      <div style="display:flex; align-items:center; gap:16px;">>
      </div>
      <div class="search-wrap">
        <input type="text" class="search-input" id="book-search" placeholder="Search <%= genre.name %>..."
          autocomplete="off" />
        <span class="search-icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
          </svg>
        </span>
        <div id="search-dropdown"></div>
      </div>
    </div>

    <!-- Books grid -->
    <div class="books-section">
      <div class="books-grid">
        <% books.forEach((book, i)=> { %>
          <div class="book-card">
            <div class="cover-wrap">
              <img src="<%= book.image.url %>" alt="<%= book.title %>" class="book-img" loading="lazy"
                onerror="this.onerror=null; this.src='/images/fallback-cover.jpg';" />
              <div class="shelf-overlay">
                <% if (currentUser) { %>
                  <button class="add-btn" onclick="addToShelf(this)"
                    data-title="<%= book.title.replace(/'/g,'&apos;').replace(/" /g,'&quot;') %>"
                    data-author="<%= book.author.replace(/'/g,'&apos;') %>"
                      data-coverurl="<%= book.image.url %>"
                        data-genre="<%= genre.name %>">
                          + Add to Shelf
                  </button>
                  <% } else { %>
                    <a href="/auth/login" style="background:#c9a96e;color:#1a0a00;padding:9px 18px;border-radius:9999px;
                        font-size:12px;font-weight:700;text-decoration:none;">
                      Login to Save
                    </a>
                    <% } %>
              </div>
            </div>
          </div>
          <% }) %>
      </div>
    </div>

    <!-- Pagination -->
    <% if (totalPages> 1) { %>
      <div class="pagination">
        <a href="/genre/<%= genre.slug %>?page=<%= currentPage - 1 %>"
          class="page-btn <%= currentPage === 1 ? 'disabled' : '' %>">&#8592; Prev</a>
        <% for (let i=1; i <=totalPages; i++) { %>
          <a href="/genre/<%= genre.slug %>?page=<%= i %>" class="page-btn <%= i === currentPage ? 'active' : '' %>">
            <%= i %>
          </a>
          <% } %>
            <a href="/genre/<%= genre.slug %>?page=<%= currentPage + 1 %>"
              class="page-btn <%= currentPage === totalPages ? 'disabled' : '' %>">Next &#8594;</a>
      </div>
      <% } %>

        <%- include('../partials/footer') %>
  </div>

  <div id="toast"></div>

  <script>
    const PAGE_BOOKS = <% - JSON.stringify(books) %>;
    const GENRE_NAME = '<%= genre.name %>';
    const IS_AUTH = <%= currentUser ? 'true' : 'false' %>;

    // ── FIX 3: Add to shelf — generate openLibraryId from title ──────────────
    async function addToShelf(btn) {
      btn.textContent = '...'; btn.disabled = true;
      const openLibraryId = 'local:' + btn.dataset.title.toLowerCase().replace(/[^a-z0-9]/g, '-');
      try {
        const res = await fetch('/books/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            openLibraryId,
            title: btn.dataset.title,
            author: btn.dataset.author,
            coverUrl: btn.dataset.coverurl,
            genre: btn.dataset.genre,
          })
        });
        const json = await res.json();
        showToast(json.message);
        if (json.success) { btn.textContent = '✓ Saved'; btn.classList.add('saved'); }
        else { btn.textContent = '+ Add to Shelf'; btn.disabled = false; }
      } catch {
        showToast('Something went wrong.');
        btn.textContent = '+ Add to Shelf'; btn.disabled = false;
      }
    }

    // ── FIX 2: Search — hits Open Library API like the original ──────────────
    const searchInput = document.getElementById('book-search');
    const searchDropdown = document.getElementById('search-dropdown');
    let searchTimeout;

    searchInput.addEventListener('input', function () {
      clearTimeout(searchTimeout);
      const q = this.value.trim();
      if (q.length < 2) { searchDropdown.style.display = 'none'; return; }

      searchTimeout = setTimeout(async () => {
        try {
          const res = await fetch(`/books/search?q=${encodeURIComponent(q)}`);
          const data = await res.json();

          if (!data.books || data.books.length === 0) {
            searchDropdown.innerHTML = `<div style="padding:16px;text-align:center;color:rgba(255,255,255,0.4);font-size:13px;">No results found</div>`;
            searchDropdown.style.display = 'block';
            return;
          }

          searchDropdown.innerHTML = data.books.map(b => `
          <div class="drop-item">
            <img src="${b.coverUrl || '/images/fallback-cover.jpg'}" class="drop-cover"
                 onerror="this.src='/images/fallback-cover.jpg'"/>
            <div style="flex:1;min-width:0;">
              <p class="drop-title">${b.title}</p>
              <p class="drop-author">${b.author}</p>
            </div>
            ${IS_AUTH ? `
              <button class="drop-btn"
                onclick="addFromSearch(this)"
                data-id="${b.id}"
                data-title="${b.title.replace(/"/g, '&quot;')}"
                data-author="${b.author.replace(/"/g, '&quot;')}"
                data-coverurl="${b.coverUrl || ''}"
                data-genre="${GENRE_NAME}">+ Add</button>
            ` : `
              <a href="/auth/login" class="drop-btn" style="text-decoration:none;">Login</a>
            `}
          </div>`).join('');

          searchDropdown.style.display = 'block';
        } catch (e) {
          searchDropdown.style.display = 'none';
        }
      }, 400);
    });

    document.addEventListener('click', e => {
      if (!searchInput.contains(e.target) && !searchDropdown.contains(e.target))
        searchDropdown.style.display = 'none';
    });

    async function addFromSearch(btn) {
      btn.textContent = '...'; btn.disabled = true;
      try {
        const res = await fetch('/books/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            openLibraryId: btn.dataset.id,
            title: btn.dataset.title,
            author: btn.dataset.author,
            coverUrl: btn.dataset.coverurl,
            genre: btn.dataset.genre,
          })
        });
        const json = await res.json();
        showToast(json.message);
        if (json.success) { btn.textContent = '✓'; btn.style.background = '#4ade80'; }
        else { btn.textContent = '+ Add'; btn.disabled = false; }
      } catch { btn.textContent = '+ Add'; btn.disabled = false; }
    }

    // ── Toast ─────────────────────────────────────────────────────────────────
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg; t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3000);
    }
  </script>
</body>

</html>