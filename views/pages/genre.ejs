<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
  <style>
    .genre-hero {
      background-image: url('<%= genre.bgImage %>');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }
    @keyframes fadeInUp {
      from { opacity:0; transform:translateY(20px); }
      to   { opacity:1; transform:translateY(0); }
    }
    .book-item {
      animation: fadeInUp 0.5s ease forwards;
      opacity: 0;
    }
    /* Toast notification */
    #toast {
      transition: all 0.3s ease;
      transform: translateY(100px);
      opacity: 0;
    }
    #toast.show {
      transform: translateY(0);
      opacity: 1;
    }
  </style>
</head>
<body class="bg-cream min-h-screen">

  <%- include('../partials/navbar') %>

  <!-- ── Genre Hero ──────────────────────────────────────────────────────── -->
  <div class="genre-hero min-h-[60vh] flex items-end relative pt-16">
    <!-- Dark overlay with genre color tint -->
    <div class="absolute inset-0"
         style="background: linear-gradient(to bottom,
           rgba(0,0,0,0.3) 0%,
           rgba(0,0,0,0.5) 50%,
           rgba(0,0,0,0.85) 100%)">
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 pb-16 w-full">
      <a href="/explore"
         class="inline-flex items-center gap-1 text-white/60 hover:text-white
                text-sm mb-6 transition-colors">
        ← Back to Explore
      </a>
      <div class="flex items-center gap-4 mb-3">
        <span class="text-5xl"><%= genre.emoji %></span>
        <h1 class="font-serif text-5xl md:text-7xl font-bold text-white">
          <%= genre.name %>
        </h1>
      </div>
      <p class="text-white/75 text-lg max-w-xl"><%= genre.description %></p>
      <p class="text-white/50 text-sm mt-3">
        Showing <%= books.length %> books · Powered by Open Library
      </p>
    </div>
  </div>

  <!-- ── Books Grid ──────────────────────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-4 py-16">

    <% if (typeof apiError !== 'undefined' && apiError) { %>
      <div class="text-center py-12">
        <p class="text-5xl mb-4">📡</p>
        <p class="text-amber-700 text-lg">Couldn't reach Open Library right now.</p>
        <p class="text-amber-500 text-sm mt-1">Try refreshing the page.</p>
      </div>
    <% } else if (books.length === 0) { %>
      <div class="text-center py-12">
        <p class="text-5xl mb-4">🔍</p>
        <p class="text-amber-700 text-lg">No books found for this genre.</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        <% books.forEach((book, i) => { %>
          <div class="book-item group cursor-pointer"
               style="animation-delay: '<%= i * 0.05 %>s'">

            <!-- Book cover -->
            <div class="relative overflow-hidden rounded-lg shadow-md
                        group-hover:shadow-2xl transition-all duration-300
                        group-hover:-translate-y-2" style="height: 200px;">
              <img
                src="<%= book.coverUrl %>"
                alt="<%= book.title %>"
                class="w-full h-full object-cover"
                onerror="this.src='/images/fallback-cover.jpg'"
              />

              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100
                          transition-opacity duration-300 flex flex-col justify-end p-3">
                <% if (currentUser) { %>
                  <button
                    onclick="addToShelf(this)"
                    data-id="<%= book.openLibraryId %>"
                    data-title="<%= book.title.replace(/'/g, '&apos;').replace(/"/g, '&quot;') %>"
                    data-author="<%= (book.author || 'Unknown').replace(/'/g, '&apos;') %>"
                    data-coverid="<%= book.coverId || '' %>"
                    data-coverurl="<%= book.coverUrl %>"
                    data-genre="<%= genre.name %>"
                    class="w-full bg-amber-400 hover:bg-amber-300 text-amber-900
                           font-semibold text-xs py-2 px-3 rounded-full
                           transition-colors duration-200 mb-1">
                    + Add to Shelf
                  </button>
                <% } else { %>
                  <a href="/auth/login"
                     class="block text-center bg-white/90 text-amber-900
                            font-semibold text-xs py-2 px-3 rounded-full">
                    Login to Save
                  </a>
                <% } %>
              </div>
            </div>

            <!-- Book info -->
            <div class="mt-2 px-1">
              <h3 class="font-serif text-xs font-semibold text-amber-900
                         line-clamp-2 leading-tight">
                <%= book.title %>
              </h3>
              <p class="text-amber-600 text-xs mt-0.5"><%= book.author %></p>
              <% if (book.year) { %>
                <p class="text-amber-400 text-xs"><%= book.year %></p>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  <%- include('../partials/footer') %>

  <!-- Toast notification -->
  <div id="toast"
       class="fixed bottom-6 right-6 bg-amber-900 text-white px-5 py-3
              rounded-full shadow-lg text-sm font-medium z-50">
    <span id="toast-msg"></span>
  </div>

  <script>
    async function addToShelf(btn) {
      const data = {
        openLibraryId: btn.dataset.id,
        title:         btn.dataset.title,
        author:        btn.dataset.author,
        coverId:       btn.dataset.coverid,
        coverUrl:      btn.dataset.coverurl,
        genre:         btn.dataset.genre || 'General',
        publishYear:   btn.dataset.year || ''
      };

      btn.textContent = '...';
      btn.disabled = true;

      try {
        const res  = await fetch('/books/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const json = await res.json();
        showToast(json.message);
        if (json.success) {
          btn.textContent = '✓ Saved';
          btn.classList.replace('bg-amber-400', 'bg-green-500');
        } else {
          btn.textContent = '+ Add to Shelf';
          btn.disabled = false;
        }
      } catch (e) {
        showToast('Something went wrong.');
        btn.textContent = '+ Add to Shelf';
        btn.disabled = false;
      }
    }

    function showToast(msg) {
      const t = document.getElementById('toast');
      document.getElementById('toast-msg').textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3000);
    }

    // Stagger animation on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.style.opacity = '1'; });
    }, { threshold: 0.1 });
    document.querySelectorAll('.book-item').forEach(el => observer.observe(el));
  </script>
</body>
</html>